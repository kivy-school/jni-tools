from typing import Any, ClassVar, overload
from java.lang.annotation.Annotation import Annotation
from java.lang.reflect.Method import Method
from java.lang.reflect.Type import Type

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class AnnotatedType:
    """Forward declaration for ``java.lang.reflect.AnnotatedType``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('java.lang.reflect.AnnotatedType')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://docs.oracle.com/javase/8/docs/api/java/lang/reflect/AnnotatedType.html
    """
    ...

class RecordComponent:
    def getName(self) -> str: ...
    def toString(self) -> str: ...
    def getAnnotation(self, p0: type) -> Annotation: ...
    def getAnnotations(self) -> Any: ...
    def getDeclaredAnnotations(self) -> Any: ...
    def getGenericSignature(self) -> str: ...
    def getGenericType(self) -> Type: ...
    def getType(self) -> type: ...
    def getAnnotatedType(self) -> AnnotatedType: ...
    def getDeclaringRecord(self) -> type: ...
    def getAccessor(self) -> Method: ...
