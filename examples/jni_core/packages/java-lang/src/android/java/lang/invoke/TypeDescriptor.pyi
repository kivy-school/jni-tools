from typing import Any, ClassVar, overload

class TypeDescriptor:
    def descriptorString(self) -> str: ...

    class OfMethod:
        def returnType(self) -> Any: ...
        def parameterType(self, p0: int) -> Any: ...
        def insertParameterTypes(self, p0: int, p1: Any) -> Any: ...
        def changeReturnType(self, p0: Any) -> Any: ...
        def dropParameterTypes(self, p0: int, p1: int) -> Any: ...
        def parameterCount(self) -> int: ...
        def parameterArray(self) -> Any: ...
        def changeParameterType(self, p0: int, p1: Any) -> Any: ...
        def parameterList(self) -> list: ...

    class OfField:
        def isArray(self) -> bool: ...
        def isPrimitive(self) -> bool: ...
        def componentType(self) -> Any: ...
        def arrayType(self) -> Any: ...
