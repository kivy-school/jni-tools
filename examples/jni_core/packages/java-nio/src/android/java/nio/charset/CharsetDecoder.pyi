from typing import Any, ClassVar, overload
from java.nio.ByteBuffer import ByteBuffer
from java.nio.CharBuffer import CharBuffer
from java.nio.charset.Charset import Charset
from java.nio.charset.CoderResult import CoderResult
from java.nio.charset.CodingErrorAction import CodingErrorAction

class CharsetDecoder:
    def reset(self) -> "CharsetDecoder": ...
    def maxCharsPerByte(self) -> float: ...
    def onMalformedInput(self, p0: CodingErrorAction) -> "CharsetDecoder": ...
    def onUnmappableCharacter(self, p0: CodingErrorAction) -> "CharsetDecoder": ...
    @overload
    def decode(self, p0: ByteBuffer) -> CharBuffer: ...
    @overload
    def decode(self, p0: ByteBuffer, p1: CharBuffer, p2: bool) -> CoderResult: ...
    def flush(self, p0: CharBuffer) -> CoderResult: ...
    def charset(self) -> Charset: ...
    def replacement(self) -> str: ...
    def malformedInputAction(self) -> CodingErrorAction: ...
    def unmappableCharacterAction(self) -> CodingErrorAction: ...
    def replaceWith(self, p0: str) -> "CharsetDecoder": ...
    def averageCharsPerByte(self) -> float: ...
    def isAutoDetecting(self) -> bool: ...
    def isCharsetDetected(self) -> bool: ...
    def detectedCharset(self) -> Charset: ...
