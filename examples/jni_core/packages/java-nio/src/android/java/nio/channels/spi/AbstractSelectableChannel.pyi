from typing import Any, ClassVar, overload
from java.nio.channels.SelectableChannel import SelectableChannel
from java.nio.channels.SelectionKey import SelectionKey
from java.nio.channels.Selector import Selector
from java.nio.channels.spi.SelectorProvider import SelectorProvider

class AbstractSelectableChannel:
    def isBlocking(self) -> bool: ...
    def keyFor(self, p0: Selector) -> SelectionKey: ...
    def isRegistered(self) -> bool: ...
    def register(self, p0: Selector, p1: int, p2: Any) -> SelectionKey: ...
    def provider(self) -> SelectorProvider: ...
    def blockingLock(self) -> Any: ...
    def configureBlocking(self, p0: bool) -> SelectableChannel: ...
