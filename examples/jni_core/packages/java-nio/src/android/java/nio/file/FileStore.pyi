from typing import Any, ClassVar, overload
from java.nio.file.attribute.FileStoreAttributeView import FileStoreAttributeView

class FileStore:
    def name(self) -> str: ...
    def type(self) -> str: ...
    def getUnallocatedSpace(self) -> int: ...
    @overload
    def supportsFileAttributeView(self, p0: type) -> bool: ...
    @overload
    def supportsFileAttributeView(self, p0: str) -> bool: ...
    def getFileStoreAttributeView(self, p0: type) -> FileStoreAttributeView: ...
    def isReadOnly(self) -> bool: ...
    def getAttribute(self, p0: str) -> Any: ...
    def getBlockSize(self) -> int: ...
    def getTotalSpace(self) -> int: ...
    def getUsableSpace(self) -> int: ...
