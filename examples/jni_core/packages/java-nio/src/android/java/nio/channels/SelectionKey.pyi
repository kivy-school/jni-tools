from typing import Any, ClassVar, overload
from java.nio.channels.SelectableChannel import SelectableChannel
from java.nio.channels.Selector import Selector

class SelectionKey:
    OP_READ: ClassVar[int]
    OP_WRITE: ClassVar[int]
    OP_CONNECT: ClassVar[int]
    OP_ACCEPT: ClassVar[int]
    def isConnectable(self) -> bool: ...
    @overload
    def interestOps(self) -> int: ...
    @overload
    def interestOps(self, p0: int) -> "SelectionKey": ...
    def cancel(self) -> None: ...
    def attachment(self) -> Any: ...
    def attach(self, p0: Any) -> Any: ...
    def channel(self) -> SelectableChannel: ...
    def readyOps(self) -> int: ...
    def interestOpsOr(self, p0: int) -> int: ...
    def interestOpsAnd(self, p0: int) -> int: ...
    def isAcceptable(self) -> bool: ...
    def selector(self) -> Selector: ...
    def isValid(self) -> bool: ...
    def isWritable(self) -> bool: ...
    def isReadable(self) -> bool: ...
