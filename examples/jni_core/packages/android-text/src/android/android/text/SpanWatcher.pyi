from typing import Any, ClassVar, overload
from android.text.Spannable import Spannable

class SpanWatcher:
    def onSpanAdded(self, p0: Spannable, p1: Any, p2: int, p3: int) -> None: ...
    def onSpanChanged(self, p0: Spannable, p1: Any, p2: int, p3: int, p4: int, p5: int) -> None: ...
    def onSpanRemoved(self, p0: Spannable, p1: Any, p2: int, p3: int) -> None: ...
