from typing import Any, ClassVar, overload

class SegmentFinder:
    DONE: ClassVar[int]
    def __init__(self) -> None: ...
    def previousEndBoundary(self, p0: int) -> int: ...
    def previousStartBoundary(self, p0: int) -> int: ...
    def nextStartBoundary(self, p0: int) -> int: ...
    def nextEndBoundary(self, p0: int) -> int: ...

    class PrescribedSegmentFinder:
        DONE: ClassVar[int]
        def __init__(self, p0: Any) -> None: ...
        def previousEndBoundary(self, p0: int) -> int: ...
        def previousStartBoundary(self, p0: int) -> int: ...
        def nextStartBoundary(self, p0: int) -> int: ...
        def nextEndBoundary(self, p0: int) -> int: ...
