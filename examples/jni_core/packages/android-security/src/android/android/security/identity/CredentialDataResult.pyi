from typing import Any, ClassVar, overload

class CredentialDataResult:
    def getDeviceMac(self) -> Any: ...
    def getDeviceSignature(self) -> Any: ...
    def getDeviceNameSpaces(self) -> Any: ...
    def getDeviceSignedEntries(self) -> Any: ...
    def getIssuerSignedEntries(self) -> Any: ...
    def getStaticAuthenticationData(self) -> Any: ...

    class Entries:
        STATUS_NOT_IN_REQUEST_MESSAGE: ClassVar[int]
        STATUS_NOT_REQUESTED: ClassVar[int]
        STATUS_NO_ACCESS_CONTROL_PROFILES: ClassVar[int]
        STATUS_NO_SUCH_ENTRY: ClassVar[int]
        STATUS_OK: ClassVar[int]
        STATUS_READER_AUTHENTICATION_FAILED: ClassVar[int]
        STATUS_USER_AUTHENTICATION_FAILED: ClassVar[int]
        def getStatus(self, p0: str, p1: str) -> int: ...
        def getEntryNames(self, p0: str) -> list: ...
        def getRetrievedEntryNames(self, p0: str) -> list: ...
        def getNamespaces(self) -> list: ...
        def getEntry(self, p0: str, p1: str) -> Any: ...
