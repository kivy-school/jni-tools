from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress
from java.net.SocketAddress import SocketAddress

class DatagramPacket:
    @overload
    def __init__(self, p0: Any, p1: int, p2: InetAddress, p3: int) -> None: ...
    @overload
    def __init__(self, p0: Any, p1: int, p2: SocketAddress) -> None: ...
    @overload
    def __init__(self, p0: Any, p1: int, p2: int) -> None: ...
    @overload
    def __init__(self, p0: Any, p1: int) -> None: ...
    @overload
    def __init__(self, p0: Any, p1: int, p2: int, p3: InetAddress, p4: int) -> None: ...
    @overload
    def __init__(self, p0: Any, p1: int, p2: int, p3: SocketAddress) -> None: ...
    def setPort(self, p0: int) -> None: ...
    def setAddress(self, p0: InetAddress) -> None: ...
    def getLength(self) -> int: ...
    def setLength(self, p0: int) -> None: ...
    def getPort(self) -> int: ...
    def getOffset(self) -> int: ...
    def getAddress(self) -> InetAddress: ...
    @overload
    def setData(self, p0: Any, p1: int, p2: int) -> None: ...
    @overload
    def setData(self, p0: Any) -> None: ...
    def getData(self) -> Any: ...
    def setSocketAddress(self, p0: SocketAddress) -> None: ...
    def getSocketAddress(self) -> SocketAddress: ...
