from typing import Any, ClassVar, overload
from android.graphics.Color import Color

class PropertyReader:
    @overload
    def readColor(self, p0: int, p1: int) -> None: ...
    @overload
    def readColor(self, p0: int, p1: int) -> None: ...
    @overload
    def readColor(self, p0: int, p1: Color) -> None: ...
    def readGravity(self, p0: int, p1: int) -> None: ...
    def readIntEnum(self, p0: int, p1: int) -> None: ...
    def readIntFlag(self, p0: int, p1: int) -> None: ...
    def readResourceId(self, p0: int, p1: int) -> None: ...
    def readObject(self, p0: int, p1: Any) -> None: ...
    def readInt(self, p0: int, p1: int) -> None: ...
    def readBoolean(self, p0: int, p1: bool) -> None: ...
    def readByte(self, p0: int, p1: int) -> None: ...
    def readShort(self, p0: int, p1: int) -> None: ...
    def readLong(self, p0: int, p1: int) -> None: ...
    def readDouble(self, p0: int, p1: float) -> None: ...
    def readChar(self, p0: int, p1: str) -> None: ...
    def readFloat(self, p0: int, p1: float) -> None: ...

    class PropertyTypeMismatchException:
        @overload
        def __init__(self, p0: int, p1: str, p2: str, p3: str) -> None: ...
        @overload
        def __init__(self, p0: int, p1: str, p2: str) -> None: ...
