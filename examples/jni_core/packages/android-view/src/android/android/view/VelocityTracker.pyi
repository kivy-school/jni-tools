from typing import Any, ClassVar, overload
from android.view.MotionEvent import MotionEvent

class VelocityTracker:
    def addMovement(self, p0: MotionEvent) -> None: ...
    def isAxisSupported(self, p0: int) -> bool: ...
    @overload
    def computeCurrentVelocity(self, p0: int, p1: float) -> None: ...
    @overload
    def computeCurrentVelocity(self, p0: int) -> None: ...
    @overload
    def getXVelocity(self, p0: int) -> float: ...
    @overload
    def getXVelocity(self) -> float: ...
    @overload
    def getYVelocity(self, p0: int) -> float: ...
    @overload
    def getYVelocity(self) -> float: ...
    @overload
    def getAxisVelocity(self, p0: int, p1: int) -> float: ...
    @overload
    def getAxisVelocity(self, p0: int) -> float: ...
    def clear(self) -> None: ...
    @staticmethod
    def obtain() -> "VelocityTracker": ...
    def recycle(self) -> None: ...
