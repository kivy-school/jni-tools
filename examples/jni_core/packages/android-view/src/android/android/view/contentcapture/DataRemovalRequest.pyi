from typing import Any, ClassVar, overload
from android.content.LocusId import LocusId
from android.os.Parcel import Parcel

class DataRemovalRequest:
    CREATOR: ClassVar[Any]
    FLAG_IS_PREFIX: ClassVar[int]
    CONTENTS_FILE_DESCRIPTOR: ClassVar[int]
    PARCELABLE_WRITE_RETURN_VALUE: ClassVar[int]
    def getLocusIdRequests(self) -> list: ...
    def isForEverything(self) -> bool: ...
    def getPackageName(self) -> str: ...
    def describeContents(self) -> int: ...
    def writeToParcel(self, p0: Parcel, p1: int) -> None: ...

    class LocusIdRequest:
        def getFlags(self) -> int: ...
        def getLocusId(self) -> LocusId: ...

    class Builder:
        def __init__(self) -> None: ...
        def addLocusId(self, p0: LocusId, p1: int) -> Any: ...
        def forEverything(self) -> Any: ...
        def build(self) -> "DataRemovalRequest": ...
