from typing import Any, ClassVar, overload
from android.os.Looper import Looper

class HandlerThread:
    MIN_PRIORITY: ClassVar[int]
    NORM_PRIORITY: ClassVar[int]
    MAX_PRIORITY: ClassVar[int]
    @overload
    def __init__(self, p0: str) -> None: ...
    @overload
    def __init__(self, p0: str, p1: int) -> None: ...
    def run(self) -> None: ...
    def getThreadId(self) -> int: ...
    def quit(self) -> bool: ...
    def quitSafely(self) -> bool: ...
    def getLooper(self) -> Looper: ...
