from typing import Any, ClassVar, overload
from java.nio.CharBuffer import CharBuffer

class CharArrayReader:
    @overload
    def __init__(self, p0: Any) -> None: ...
    @overload
    def __init__(self, p0: Any, p1: int, p2: int) -> None: ...
    def reset(self) -> None: ...
    @overload
    def read(self, p0: CharBuffer) -> int: ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    @overload
    def read(self) -> int: ...
    def close(self) -> None: ...
    def mark(self, p0: int) -> None: ...
    def skip(self, p0: int) -> int: ...
    def markSupported(self) -> bool: ...
    def ready(self) -> bool: ...
