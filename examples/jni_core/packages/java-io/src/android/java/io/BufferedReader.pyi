from typing import Any, ClassVar, overload
from java.io.Reader import Reader
from java.util.stream.Stream import Stream

class BufferedReader:
    @overload
    def __init__(self, p0: Reader, p1: int) -> None: ...
    @overload
    def __init__(self, p0: Reader) -> None: ...
    def reset(self) -> None: ...
    def lines(self) -> Stream: ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    @overload
    def read(self) -> int: ...
    def readLine(self) -> str: ...
    def close(self) -> None: ...
    def mark(self, p0: int) -> None: ...
    def skip(self, p0: int) -> int: ...
    def markSupported(self) -> bool: ...
    def ready(self) -> bool: ...
