from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.io.Reader import Reader

class StreamTokenizer:
    TT_EOF: ClassVar[int]
    TT_EOL: ClassVar[int]
    TT_NUMBER: ClassVar[int]
    TT_WORD: ClassVar[int]
    ttype: int
    sval: str
    nval: float
    @overload
    def __init__(self, p0: Reader) -> None: ...
    @overload
    def __init__(self, p0: InputStream) -> None: ...
    def toString(self) -> str: ...
    def nextToken(self) -> int: ...
    def pushBack(self) -> None: ...
    def wordChars(self, p0: int, p1: int) -> None: ...
    def whitespaceChars(self, p0: int, p1: int) -> None: ...
    def commentChar(self, p0: int) -> None: ...
    def quoteChar(self, p0: int) -> None: ...
    def parseNumbers(self) -> None: ...
    def resetSyntax(self) -> None: ...
    def ordinaryChars(self, p0: int, p1: int) -> None: ...
    def ordinaryChar(self, p0: int) -> None: ...
    def eolIsSignificant(self, p0: bool) -> None: ...
    def slashStarComments(self, p0: bool) -> None: ...
    def slashSlashComments(self, p0: bool) -> None: ...
    def lowerCaseMode(self, p0: bool) -> None: ...
    def lineno(self) -> int: ...
