from typing import Any, ClassVar, overload

class StringBufferInputStream:
    def __init__(self, p0: str) -> None: ...
    def reset(self) -> None: ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    @overload
    def read(self) -> int: ...
    def skip(self, p0: int) -> int: ...
    def available(self) -> int: ...
