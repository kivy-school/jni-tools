from typing import Any, ClassVar, overload
from android.se.omapi.Channel import Channel
from android.se.omapi.Reader import Reader

class Session:
    def close(self) -> None: ...
    def isClosed(self) -> bool: ...
    def getReader(self) -> Reader: ...
    @overload
    def openBasicChannel(self, p0: Any, p1: int) -> Channel: ...
    @overload
    def openBasicChannel(self, p0: Any) -> Channel: ...
    def getATR(self) -> Any: ...
    def closeChannels(self) -> None: ...
    @overload
    def openLogicalChannel(self, p0: Any) -> Channel: ...
    @overload
    def openLogicalChannel(self, p0: Any, p1: int) -> Channel: ...
