from typing import Any, ClassVar, overload
from javax.crypto.SecretKey import SecretKey

class ExtendedSSLSession:
    def __init__(self) -> None: ...
    def getLocalSupportedSignatureAlgorithms(self) -> Any: ...
    def getPeerSupportedSignatureAlgorithms(self) -> Any: ...
    def getRequestedServerNames(self) -> list: ...
    def getStatusResponses(self) -> list: ...
    def exportKeyingMaterialKey(self, p0: str, p1: str, p2: Any, p3: int) -> SecretKey: ...
    def exportKeyingMaterialData(self, p0: str, p1: Any, p2: int) -> Any: ...
