from typing import Any, ClassVar, overload
from org.w3c.dom.Node import Node

class DOMResult:
    FEATURE: ClassVar[str]
    PI_DISABLE_OUTPUT_ESCAPING: ClassVar[str]
    PI_ENABLE_OUTPUT_ESCAPING: ClassVar[str]
    @overload
    def __init__(self, p0: Node, p1: Node) -> None: ...
    @overload
    def __init__(self, p0: Node, p1: Node, p2: str) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: Node, p1: str) -> None: ...
    @overload
    def __init__(self, p0: Node) -> None: ...
    def getSystemId(self) -> str: ...
    def getNode(self) -> Node: ...
    def setNode(self, p0: Node) -> None: ...
    def setSystemId(self, p0: str) -> None: ...
    def setNextSibling(self, p0: Node) -> None: ...
    def getNextSibling(self) -> Node: ...
