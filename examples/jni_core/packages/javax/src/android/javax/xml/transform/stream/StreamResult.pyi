from typing import Any, ClassVar, overload
from java.io.File import File
from java.io.OutputStream import OutputStream
from java.io.Writer import Writer

class StreamResult:
    FEATURE: ClassVar[str]
    PI_DISABLE_OUTPUT_ESCAPING: ClassVar[str]
    PI_ENABLE_OUTPUT_ESCAPING: ClassVar[str]
    @overload
    def __init__(self, p0: str) -> None: ...
    @overload
    def __init__(self, p0: File) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: OutputStream) -> None: ...
    @overload
    def __init__(self, p0: Writer) -> None: ...
    def getSystemId(self) -> str: ...
    def setOutputStream(self, p0: OutputStream) -> None: ...
    @overload
    def setSystemId(self, p0: str) -> None: ...
    @overload
    def setSystemId(self, p0: File) -> None: ...
    def getOutputStream(self) -> OutputStream: ...
    def setWriter(self, p0: Writer) -> None: ...
    def getWriter(self) -> Writer: ...
