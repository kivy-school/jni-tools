from typing import Any, ClassVar, overload

class TimeAnimator:
    INFINITE: ClassVar[int]
    RESTART: ClassVar[int]
    REVERSE: ClassVar[int]
    DURATION_INFINITE: ClassVar[int]
    def __init__(self) -> None: ...
    def setTimeListener(self, p0: Any) -> None: ...
    def start(self) -> None: ...
    def setCurrentPlayTime(self, p0: int) -> None: ...

    class TimeListener:
        def onTimeUpdate(self, p0: "TimeAnimator", p1: int, p2: int) -> None: ...
