from typing import Any, ClassVar, overload
from java.text.CollationKey import CollationKey
from java.util.Locale import Locale

class Collator:
    PRIMARY: ClassVar[int]
    SECONDARY: ClassVar[int]
    TERTIARY: ClassVar[int]
    IDENTICAL: ClassVar[int]
    NO_DECOMPOSITION: ClassVar[int]
    CANONICAL_DECOMPOSITION: ClassVar[int]
    FULL_DECOMPOSITION: ClassVar[int]
    def getDecomposition(self) -> int: ...
    def setStrength(self, p0: int) -> None: ...
    def setDecomposition(self, p0: int) -> None: ...
    def getStrength(self) -> int: ...
    def getCollationKey(self, p0: str) -> CollationKey: ...
    @overload
    def equals(self, p0: Any) -> bool: ...
    @overload
    def equals(self, p0: str, p1: str) -> bool: ...
    def hashCode(self) -> int: ...
    def clone(self) -> Any: ...
    @overload
    def compare(self, p0: Any, p1: Any) -> int: ...
    @overload
    def compare(self, p0: str, p1: str) -> int: ...
    @overload
    @staticmethod
    def getInstance(p0: Locale) -> "Collator": ...
    @overload
    @staticmethod
    def getInstance() -> "Collator": ...
    @staticmethod
    def getAvailableLocales() -> Any: ...
