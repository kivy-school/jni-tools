from typing import Any, ClassVar, overload

class MidiReceiver:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: int) -> None: ...
    def onFlush(self) -> None: ...
    def onSend(self, p0: Any, p1: int, p2: int, p3: int) -> None: ...
    def getMaxMessageSize(self) -> int: ...
    def flush(self) -> None: ...
    @overload
    def send(self, p0: Any, p1: int, p2: int, p3: int) -> None: ...
    @overload
    def send(self, p0: Any, p1: int, p2: int) -> None: ...
