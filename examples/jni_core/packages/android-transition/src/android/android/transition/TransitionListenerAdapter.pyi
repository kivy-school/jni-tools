from typing import Any, ClassVar, overload
from android.transition.Transition import Transition

class TransitionListenerAdapter:
    def __init__(self) -> None: ...
    def onTransitionEnd(self, p0: Transition) -> None: ...
    def onTransitionCancel(self, p0: Transition) -> None: ...
    def onTransitionStart(self, p0: Transition) -> None: ...
    def onTransitionPause(self, p0: Transition) -> None: ...
    def onTransitionResume(self, p0: Transition) -> None: ...
