from typing import Any, ClassVar, overload
from android.transition.Scene import Scene
from android.transition.Transition import Transition
from android.view.ViewGroup import ViewGroup

class TransitionManager:
    def __init__(self) -> None: ...
    @overload
    def setTransition(self, p0: Scene, p1: Scene, p2: Transition) -> None: ...
    @overload
    def setTransition(self, p0: Scene, p1: Transition) -> None: ...
    @overload
    @staticmethod
    def go(p0: Scene, p1: Transition) -> None: ...
    @overload
    @staticmethod
    def go(p0: Scene) -> None: ...
    def transitionTo(self, p0: Scene) -> None: ...
    @overload
    @staticmethod
    def beginDelayedTransition(p0: ViewGroup, p1: Transition) -> None: ...
    @overload
    @staticmethod
    def beginDelayedTransition(p0: ViewGroup) -> None: ...
    @staticmethod
    def endTransitions(p0: ViewGroup) -> None: ...
