from typing import Any, ClassVar, overload
from java.io.File import File
from java.io.FileInputStream import FileInputStream
from java.io.FileOutputStream import FileOutputStream

class AtomicFile:
    def __init__(self, p0: File) -> None: ...
    def startWrite(self) -> FileOutputStream: ...
    def finishWrite(self, p0: FileOutputStream) -> None: ...
    def failWrite(self, p0: FileOutputStream) -> None: ...
    def getBaseFile(self) -> File: ...
    def toString(self) -> str: ...
    def delete(self) -> None: ...
    def openRead(self) -> FileInputStream: ...
    def getLastModifiedTime(self) -> int: ...
    def readFully(self) -> Any: ...
