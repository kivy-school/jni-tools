from typing import Any, ClassVar, overload
from android.net.NetworkSpecifier import NetworkSpecifier
from android.net.wifi.aware.PeerHandle import PeerHandle

class DiscoverySession:
    def initiateBootstrappingRequest(self, p0: PeerHandle, p1: int) -> None: ...
    def initiatePairingRequest(self, p0: PeerHandle, p1: str, p2: int, p3: str) -> None: ...
    def acceptPairingRequest(self, p0: int, p1: PeerHandle, p2: str, p3: int, p4: str) -> None: ...
    def rejectPairingRequest(self, p0: int, p1: PeerHandle) -> None: ...
    def createNetworkSpecifierOpen(self, p0: PeerHandle) -> NetworkSpecifier: ...
    def createNetworkSpecifierPassphrase(self, p0: PeerHandle, p1: str) -> NetworkSpecifier: ...
    def close(self) -> None: ...
    def sendMessage(self, p0: PeerHandle, p1: int, p2: Any) -> None: ...
