        cdef JNIEnv* env = get_env()
        cdef Builder inst = Builder.__new__(Builder)
        cdef jobject global_ref = jnicore_NewGlobalRef(env, (<JavaObject?>obj)._handle)
        inst._adopt_global(env, global_ref)
        return inst

