from typing import Any, ClassVar, overload
from java.lang.Runnable import Runnable
from java.util.Iterator import Iterator
from java.util.Spliterator import Spliterator

class BaseStream:
    def iterator(self) -> Iterator: ...
    def spliterator(self) -> Spliterator: ...
    def close(self) -> None: ...
    def isParallel(self) -> bool: ...
    def parallel(self) -> "BaseStream": ...
    def sequential(self) -> "BaseStream": ...
    def unordered(self) -> "BaseStream": ...
    def onClose(self, p0: Runnable) -> "BaseStream": ...
