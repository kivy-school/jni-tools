from typing import Any, ClassVar, overload
from java.lang.Runnable import Runnable
from java.util.concurrent.TimeUnit import TimeUnit

class CyclicBarrier:
    @overload
    def __init__(self, p0: int) -> None: ...
    @overload
    def __init__(self, p0: int, p1: Runnable) -> None: ...
    def reset(self) -> None: ...
    @overload
    def await_(self) -> int: ...
    @overload
    def await_(self, p0: int, p1: TimeUnit) -> int: ...
    def getParties(self) -> int: ...
    def isBroken(self) -> bool: ...
    def getNumberWaiting(self) -> int: ...
