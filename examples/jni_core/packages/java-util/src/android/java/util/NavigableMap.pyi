from typing import Any, ClassVar, overload
from java.util.NavigableSet import NavigableSet
from java.util.SequencedMap import SequencedMap
from java.util.SortedMap import SortedMap

class NavigableMap:
    @overload
    def reversed(self) -> "NavigableMap": ...
    @overload
    def reversed(self) -> SortedMap: ...
    @overload
    def reversed(self) -> SequencedMap: ...
    def descendingMap(self) -> "NavigableMap": ...
    def navigableKeySet(self) -> NavigableSet: ...
    @overload
    def subMap(self, p0: Any, p1: Any) -> SortedMap: ...
    @overload
    def subMap(self, p0: Any, p1: bool, p2: Any, p3: bool) -> "NavigableMap": ...
    @overload
    def headMap(self, p0: Any, p1: bool) -> "NavigableMap": ...
    @overload
    def headMap(self, p0: Any) -> SortedMap: ...
    @overload
    def tailMap(self, p0: Any, p1: bool) -> "NavigableMap": ...
    @overload
    def tailMap(self, p0: Any) -> SortedMap: ...
    def descendingKeySet(self) -> NavigableSet: ...
    def lowerEntry(self, p0: Any) -> Any: ...
    def lowerKey(self, p0: Any) -> Any: ...
    def floorEntry(self, p0: Any) -> Any: ...
    def floorKey(self, p0: Any) -> Any: ...
    def ceilingEntry(self, p0: Any) -> Any: ...
    def ceilingKey(self, p0: Any) -> Any: ...
    def higherEntry(self, p0: Any) -> Any: ...
    def higherKey(self, p0: Any) -> Any: ...
    def firstEntry(self) -> Any: ...
    def lastEntry(self) -> Any: ...
    def pollFirstEntry(self) -> Any: ...
    def pollLastEntry(self) -> Any: ...
