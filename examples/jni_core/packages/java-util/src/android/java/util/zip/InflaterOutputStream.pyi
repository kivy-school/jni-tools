from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.util.zip.Inflater import Inflater

class InflaterOutputStream:
    @overload
    def __init__(self, p0: OutputStream, p1: Inflater) -> None: ...
    @overload
    def __init__(self, p0: OutputStream) -> None: ...
    @overload
    def __init__(self, p0: OutputStream, p1: Inflater, p2: int) -> None: ...
    def flush(self) -> None: ...
    @overload
    def write(self, p0: int) -> None: ...
    @overload
    def write(self, p0: Any, p1: int, p2: int) -> None: ...
    def close(self) -> None: ...
    def finish(self) -> None: ...
