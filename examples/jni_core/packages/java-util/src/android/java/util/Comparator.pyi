from typing import Any, ClassVar, overload
from java.util.function.Function import Function
from java.util.function.ToDoubleFunction import ToDoubleFunction
from java.util.function.ToIntFunction import ToIntFunction
from java.util.function.ToLongFunction import ToLongFunction

class Comparator:
    def equals(self, p0: Any) -> bool: ...
    def min(self, p0: Any, p1: Any) -> Any: ...
    def max(self, p0: Any, p1: Any) -> Any: ...
    def compare(self, p0: Any, p1: Any) -> int: ...
    def reversed(self) -> "Comparator": ...
    @staticmethod
    def reverseOrder() -> "Comparator": ...
    @overload
    @staticmethod
    def comparing(p0: Function) -> "Comparator": ...
    @overload
    @staticmethod
    def comparing(p0: Function, p1: "Comparator") -> "Comparator": ...
    @overload
    def thenComparing(self, p0: "Comparator") -> "Comparator": ...
    @overload
    def thenComparing(self, p0: Function, p1: "Comparator") -> "Comparator": ...
    @overload
    def thenComparing(self, p0: Function) -> "Comparator": ...
    @staticmethod
    def comparingInt(p0: ToIntFunction) -> "Comparator": ...
    @staticmethod
    def comparingLong(p0: ToLongFunction) -> "Comparator": ...
    @staticmethod
    def comparingDouble(p0: ToDoubleFunction) -> "Comparator": ...
    def thenComparingInt(self, p0: ToIntFunction) -> "Comparator": ...
    def thenComparingLong(self, p0: ToLongFunction) -> "Comparator": ...
    def thenComparingDouble(self, p0: ToDoubleFunction) -> "Comparator": ...
    @staticmethod
    def naturalOrder() -> "Comparator": ...
    @staticmethod
    def nullsFirst(p0: "Comparator") -> "Comparator": ...
    @staticmethod
    def nullsLast(p0: "Comparator") -> "Comparator": ...
