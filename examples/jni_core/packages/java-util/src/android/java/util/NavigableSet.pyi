from typing import Any, ClassVar, overload
from java.util.Iterator import Iterator
from java.util.SequencedCollection import SequencedCollection
from java.util.SequencedSet import SequencedSet
from java.util.SortedSet import SortedSet

class NavigableSet:
    def floor(self, p0: Any) -> Any: ...
    def iterator(self) -> Iterator: ...
    @overload
    def reversed(self) -> SortedSet: ...
    @overload
    def reversed(self) -> "NavigableSet": ...
    @overload
    def reversed(self) -> SequencedCollection: ...
    @overload
    def reversed(self) -> SequencedSet: ...
    def removeFirst(self) -> Any: ...
    def removeLast(self) -> Any: ...
    def lower(self, p0: Any) -> Any: ...
    def descendingSet(self) -> "NavigableSet": ...
    def ceiling(self, p0: Any) -> Any: ...
    def higher(self, p0: Any) -> Any: ...
    @overload
    def subSet(self, p0: Any, p1: bool, p2: Any, p3: bool) -> "NavigableSet": ...
    @overload
    def subSet(self, p0: Any, p1: Any) -> SortedSet: ...
    @overload
    def headSet(self, p0: Any, p1: bool) -> "NavigableSet": ...
    @overload
    def headSet(self, p0: Any) -> SortedSet: ...
    @overload
    def tailSet(self, p0: Any, p1: bool) -> "NavigableSet": ...
    @overload
    def tailSet(self, p0: Any) -> SortedSet: ...
    def pollFirst(self) -> Any: ...
    def pollLast(self) -> Any: ...
    def descendingIterator(self) -> Iterator: ...
