from typing import Any, ClassVar, overload
from android.drm.ProcessedData import ProcessedData
from java.io.File import File

class DrmRights:
    @overload
    def __init__(self, p0: str, p1: str) -> None: ...
    @overload
    def __init__(self, p0: ProcessedData, p1: str) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: str, p3: str) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: str) -> None: ...
    @overload
    def __init__(self, p0: File, p1: str) -> None: ...
    def getSubscriptionId(self) -> str: ...
    def getAccountId(self) -> str: ...
    def getData(self) -> Any: ...
    def getMimeType(self) -> str: ...
