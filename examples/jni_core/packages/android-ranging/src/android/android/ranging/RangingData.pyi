from typing import Any, ClassVar, overload
from android.os.Parcel import Parcel
from android.ranging.RangingMeasurement import RangingMeasurement

class RangingData:
    CREATOR: ClassVar[Any]
    CONTENTS_FILE_DESCRIPTOR: ClassVar[int]
    PARCELABLE_WRITE_RETURN_VALUE: ClassVar[int]
    def getDistance(self) -> RangingMeasurement: ...
    def writeToParcel(self, p0: Parcel, p1: int) -> None: ...
    def describeContents(self) -> int: ...
    def getRssi(self) -> int: ...
    def hasRssi(self) -> bool: ...
    def getRangingTechnology(self) -> int: ...
    def getAzimuth(self) -> RangingMeasurement: ...
    def getElevation(self) -> RangingMeasurement: ...
    def getTimestampMillis(self) -> int: ...
