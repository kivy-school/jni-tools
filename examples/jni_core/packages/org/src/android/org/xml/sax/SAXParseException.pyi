from typing import Any, ClassVar, overload
from java.lang.Exception import Exception
from org.xml.sax.Locator import Locator

class SAXParseException:
    @overload
    def __init__(self, p0: str, p1: str, p2: str, p3: int, p4: int, p5: Exception) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: str, p3: int, p4: int) -> None: ...
    @overload
    def __init__(self, p0: str, p1: Locator, p2: Exception) -> None: ...
    @overload
    def __init__(self, p0: str, p1: Locator) -> None: ...
    def getSystemId(self) -> str: ...
    def toString(self) -> str: ...
    def getLineNumber(self) -> int: ...
    def getColumnNumber(self) -> int: ...
    def getPublicId(self) -> str: ...
