from typing import Any, ClassVar, overload

class PathIterator:
    VERB_CLOSE: ClassVar[int]
    VERB_CONIC: ClassVar[int]
    VERB_CUBIC: ClassVar[int]
    VERB_DONE: ClassVar[int]
    VERB_LINE: ClassVar[int]
    VERB_MOVE: ClassVar[int]
    VERB_QUAD: ClassVar[int]
    def hasNext(self) -> bool: ...
    @overload
    def next(self) -> Any: ...
    @overload
    def next(self) -> Any: ...
    @overload
    def next(self, p0: Any, p1: int) -> int: ...
    def peek(self) -> int: ...

    class Segment:
        def getVerb(self) -> int: ...
        def getPoints(self) -> Any: ...
        def getConicWeight(self) -> float: ...
