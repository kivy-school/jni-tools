from typing import Any, ClassVar, overload
from android.graphics.Matrix import Matrix
from android.graphics.Path import Path

class PathMeasure:
    POSITION_MATRIX_FLAG: ClassVar[int]
    TANGENT_MATRIX_FLAG: ClassVar[int]
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: Path, p1: bool) -> None: ...
    def getPosTan(self, p0: float, p1: Any, p2: Any) -> bool: ...
    def getSegment(self, p0: float, p1: float, p2: Path, p3: bool) -> bool: ...
    def nextContour(self) -> bool: ...
    def getLength(self) -> float: ...
    def getMatrix(self, p0: float, p1: Matrix, p2: int) -> bool: ...
    def isClosed(self) -> bool: ...
    def setPath(self, p0: Path, p1: bool) -> None: ...
