from typing import Any, ClassVar, overload

class RenderParams:
    FLAG_RENDER_HIGHLIGHT_ANNOTATIONS: ClassVar[int]
    FLAG_RENDER_TEXT_ANNOTATIONS: ClassVar[int]
    RENDER_MODE_FOR_DISPLAY: ClassVar[int]
    RENDER_MODE_FOR_PRINT: ClassVar[int]
    def getRenderMode(self) -> int: ...
    def getRenderFlags(self) -> int: ...

    class Builder:
        def __init__(self, p0: int) -> None: ...
        @overload
        def setRenderFlags(self, p0: int, p1: int) -> Any: ...
        @overload
        def setRenderFlags(self, p0: int) -> Any: ...
        def build(self) -> "RenderParams": ...
