    def getValueCount(self) -> int: ...
    @overload
    def setKeyFrame(self, p0: int, p1: int, p2: Any, p3: Any) -> None: ...
    @overload
    def setKeyFrame(self, p0: int, p1: int, p2: Any) -> None: ...
    @overload
    def reset(self, p0: int) -> None: ...
    @overload
    def reset(self, p0: int, p1: int) -> None: ...

    class Result:
        FREEZE_END: ClassVar["Result"]
        FREEZE_START: ClassVar["Result"]
        NORMAL: ClassVar["Result"]
        FREEZE_END: ClassVar[Any]
        FREEZE_START: ClassVar[Any]
        NORMAL: ClassVar[Any]
