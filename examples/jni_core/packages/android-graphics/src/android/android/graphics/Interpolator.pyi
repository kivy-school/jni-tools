from typing import Any, ClassVar, overload

class Interpolator:
    @overload
    def __init__(self, p0: int) -> None: ...
    @overload
    def __init__(self, p0: int, p1: int) -> None: ...
    def getKeyFrameCount(self) -> int: ...
