    CHANNEL_GREEN: ClassVar[int]
    CHANNEL_RED: ClassVar[int]
    LEVEL_BLACK: ClassVar[float]
    LEVEL_WHITE: ClassVar[float]
    POINT_SIZE: ClassVar[int]
    def __init__(self, p0: Any, p1: Any, p2: Any) -> None: ...
    def equals(self, p0: Any) -> bool: ...
    def toString(self) -> str: ...
    def hashCode(self) -> int: ...
    def copyColorCurve(self, p0: int, p1: Any, p2: int) -> None: ...
    def getPoint(self, p0: int, p1: int) -> PointF: ...
    def getPointCount(self, p0: int) -> int: ...
