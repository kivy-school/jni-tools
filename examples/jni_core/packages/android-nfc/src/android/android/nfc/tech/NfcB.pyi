from typing import Any, ClassVar, overload
from android.nfc.Tag import Tag

class NfcB:
    def getApplicationData(self) -> Any: ...
    def getProtocolInfo(self) -> Any: ...
    def transceive(self, p0: Any) -> Any: ...
    def getMaxTransceiveLength(self) -> int: ...
    def isConnected(self) -> bool: ...
    @staticmethod
    def get(p0: Tag) -> "NfcB": ...
    def connect(self) -> None: ...
    def close(self) -> None: ...
    def getTag(self) -> Tag: ...
