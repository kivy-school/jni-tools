from typing import Any, ClassVar, overload
from java.nio.ByteBuffer import ByteBuffer
from java.security.Provider import Provider

class MessageDigest:
    def reset(self) -> None: ...
    def toString(self) -> str: ...
    def clone(self) -> Any: ...
    @overload
    def update(self, p0: ByteBuffer) -> None: ...
    @overload
    def update(self, p0: Any) -> None: ...
    @overload
    def update(self, p0: Any, p1: int, p2: int) -> None: ...
    @overload
    def update(self, p0: int) -> None: ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: str) -> "MessageDigest": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: Provider) -> "MessageDigest": ...
    @overload
    @staticmethod
    def getInstance(p0: str) -> "MessageDigest": ...
    @overload
    def digest(self) -> Any: ...
    @overload
    def digest(self, p0: Any, p1: int, p2: int) -> int: ...
    @overload
    def digest(self, p0: Any) -> Any: ...
    @staticmethod
    def isEqual(p0: Any, p1: Any) -> bool: ...
    def getProvider(self) -> Provider: ...
    def getDigestLength(self) -> int: ...
    def getAlgorithm(self) -> str: ...
