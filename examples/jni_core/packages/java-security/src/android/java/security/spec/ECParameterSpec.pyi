from typing import Any, ClassVar, overload
from java.math.BigInteger import BigInteger
from java.security.spec.ECPoint import ECPoint
from java.security.spec.EllipticCurve import EllipticCurve

class ECParameterSpec:
    def __init__(self, p0: EllipticCurve, p1: ECPoint, p2: BigInteger, p3: int) -> None: ...
    def getCurve(self) -> EllipticCurve: ...
    def getGenerator(self) -> ECPoint: ...
    def getCofactor(self) -> int: ...
    def getOrder(self) -> BigInteger: ...
