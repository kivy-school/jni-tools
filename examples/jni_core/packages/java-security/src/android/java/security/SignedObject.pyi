from typing import Any, ClassVar, overload
from java.io.Serializable import Serializable
from java.security.PrivateKey import PrivateKey
from java.security.PublicKey import PublicKey
from java.security.Signature import Signature

class SignedObject:
    def __init__(self, p0: Serializable, p1: PrivateKey, p2: Signature) -> None: ...
    def getObject(self) -> Any: ...
    def getSignature(self) -> Any: ...
    def getAlgorithm(self) -> str: ...
    def verify(self, p0: PublicKey, p1: Signature) -> bool: ...
