from typing import Any, ClassVar, overload
from java.text.CharacterIterator import CharacterIterator
from java.text.CollationElementIterator import CollationElementIterator
from java.text.CollationKey import CollationKey

class RuleBasedCollator:
    PRIMARY: ClassVar[int]
    SECONDARY: ClassVar[int]
    TERTIARY: ClassVar[int]
    IDENTICAL: ClassVar[int]
    NO_DECOMPOSITION: ClassVar[int]
    CANONICAL_DECOMPOSITION: ClassVar[int]
    FULL_DECOMPOSITION: ClassVar[int]
    def __init__(self, p0: str) -> None: ...
    @overload
    def getCollationElementIterator(self, p0: CharacterIterator) -> CollationElementIterator: ...
    @overload
    def getCollationElementIterator(self, p0: str) -> CollationElementIterator: ...
    def getCollationKey(self, p0: str) -> CollationKey: ...
    def getRules(self) -> str: ...
    def equals(self, p0: Any) -> bool: ...
    def hashCode(self) -> int: ...
    def clone(self) -> Any: ...
    def compare(self, p0: str, p1: str) -> int: ...
