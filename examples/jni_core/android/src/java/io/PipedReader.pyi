from typing import Any, ClassVar, overload
from java.io.PipedWriter import PipedWriter

class PipedReader:
    @overload
    def __init__(self, p0: PipedWriter) -> None: ...
    @overload
    def __init__(self, p0: int) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: PipedWriter, p1: int) -> None: ...
    def connect(self, p0: PipedWriter) -> None: ...
    def close(self) -> None: ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    @overload
    def read(self) -> int: ...
    def ready(self) -> bool: ...
