from typing import Any, ClassVar, overload
from java.io.Reader import Reader

class PushbackReader:
    @overload
    def __init__(self, p0: Reader) -> None: ...
    @overload
    def __init__(self, p0: Reader, p1: int) -> None: ...
    def ready(self) -> bool: ...
    def mark(self, p0: int) -> None: ...
    def skip(self, p0: int) -> int: ...
    def markSupported(self) -> bool: ...
    @overload
    def unread(self, p0: Any, p1: int, p2: int) -> None: ...
    @overload
    def unread(self, p0: Any) -> None: ...
    @overload
    def unread(self, p0: int) -> None: ...
    def reset(self) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    def close(self) -> None: ...
