from typing import Any, ClassVar, overload

class OutputStream:
    def __init__(self) -> None: ...
    def flush(self) -> None: ...
    def close(self) -> None: ...
    @overload
    def write(self, p0: Any) -> None: ...
    @overload
    def write(self, p0: Any, p1: int, p2: int) -> None: ...
    @overload
    def write(self, p0: int) -> None: ...
    @staticmethod
    def nullOutputStream() -> "OutputStream": ...
