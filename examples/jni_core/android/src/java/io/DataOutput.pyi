from typing import Any, ClassVar, overload

class DataOutput:
    @overload
    def write(self, p0: Any, p1: int, p2: int) -> None: ...
    @overload
    def write(self, p0: Any) -> None: ...
    @overload
    def write(self, p0: int) -> None: ...
    def writeInt(self, p0: int) -> None: ...
    def writeUTF(self, p0: str) -> None: ...
    def writeBytes(self, p0: str) -> None: ...
    def writeLong(self, p0: int) -> None: ...
    def writeByte(self, p0: int) -> None: ...
    def writeShort(self, p0: int) -> None: ...
    def writeBoolean(self, p0: bool) -> None: ...
    def writeDouble(self, p0: float) -> None: ...
    def writeChars(self, p0: str) -> None: ...
    def writeChar(self, p0: int) -> None: ...
    def writeFloat(self, p0: float) -> None: ...
