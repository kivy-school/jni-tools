from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.io.OutputStream import OutputStream

class PushbackInputStream:
    @overload
    def __init__(self, p0: InputStream, p1: int) -> None: ...
    @overload
    def __init__(self, p0: InputStream) -> None: ...
    def mark(self, p0: int) -> None: ...
    def transferTo(self, p0: OutputStream) -> int: ...
    def skip(self, p0: int) -> int: ...
    def available(self) -> int: ...
    def markSupported(self) -> bool: ...
    @overload
    def unread(self, p0: int) -> None: ...
    @overload
    def unread(self, p0: Any, p1: int, p2: int) -> None: ...
    @overload
    def unread(self, p0: Any) -> None: ...
    def reset(self) -> None: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    def close(self) -> None: ...
