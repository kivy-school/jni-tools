from typing import Any, ClassVar, overload
from java.io.File import File
from java.io.FileDescriptor import FileDescriptor
from java.nio.channels.FileChannel import FileChannel

class FileOutputStream:
    @overload
    def __init__(self, p0: str) -> None: ...
    @overload
    def __init__(self, p0: str, p1: bool) -> None: ...
    @overload
    def __init__(self, p0: File) -> None: ...
    @overload
    def __init__(self, p0: File, p1: bool) -> None: ...
    @overload
    def __init__(self, p0: FileDescriptor) -> None: ...
    def getChannel(self) -> FileChannel: ...
    def getFD(self) -> FileDescriptor: ...
    @overload
    def write(self, p0: Any) -> None: ...
    @overload
    def write(self, p0: int) -> None: ...
    @overload
    def write(self, p0: Any, p1: int, p2: int) -> None: ...
    def close(self) -> None: ...
