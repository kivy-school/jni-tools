from typing import Any, ClassVar, overload
from java.io.Writer import Writer

class BufferedWriter:
    @overload
    def __init__(self, p0: Writer, p1: int) -> None: ...
    @overload
    def __init__(self, p0: Writer) -> None: ...
    def flush(self) -> None: ...
    @overload
    def write(self, p0: Any, p1: int, p2: int) -> None: ...
    @overload
    def write(self, p0: int) -> None: ...
    @overload
    def write(self, p0: str, p1: int, p2: int) -> None: ...
    def newLine(self) -> None: ...
    def close(self) -> None: ...
