from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.io.OutputStream import OutputStream
from java.util.Enumeration import Enumeration

class SequenceInputStream:
    @overload
    def __init__(self, p0: Enumeration) -> None: ...
    @overload
    def __init__(self, p0: InputStream, p1: InputStream) -> None: ...
    def transferTo(self, p0: OutputStream) -> int: ...
    def available(self) -> int: ...
    @overload
    def read(self) -> int: ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    def close(self) -> None: ...
