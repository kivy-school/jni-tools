from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.util.zip.Checksum import Checksum

class CheckedOutputStream:
    def __init__(self, p0: OutputStream, p1: Checksum) -> None: ...
    def getChecksum(self) -> Checksum: ...
    @overload
    def write(self, p0: int) -> None: ...
    @overload
    def write(self, p0: Any, p1: int, p2: int) -> None: ...
