from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream
from java.util.zip.Deflater import Deflater

class DeflaterOutputStream:
    @overload
    def __init__(self, p0: OutputStream, p1: Deflater, p2: int, p3: bool) -> None: ...
    @overload
    def __init__(self, p0: OutputStream) -> None: ...
    @overload
    def __init__(self, p0: OutputStream, p1: bool) -> None: ...
    @overload
    def __init__(self, p0: OutputStream, p1: Deflater) -> None: ...
    @overload
    def __init__(self, p0: OutputStream, p1: Deflater, p2: bool) -> None: ...
    @overload
    def __init__(self, p0: OutputStream, p1: Deflater, p2: int) -> None: ...
    def finish(self) -> None: ...
    def flush(self) -> None: ...
    @overload
    def write(self, p0: int) -> None: ...
    @overload
    def write(self, p0: Any, p1: int, p2: int) -> None: ...
    def close(self) -> None: ...
