from typing import Any, ClassVar, overload
from java.io.OutputStream import OutputStream

class GZIPOutputStream:
    @overload
    def __init__(self, p0: OutputStream, p1: int) -> None: ...
    @overload
    def __init__(self, p0: OutputStream) -> None: ...
    @overload
    def __init__(self, p0: OutputStream, p1: bool) -> None: ...
    @overload
    def __init__(self, p0: OutputStream, p1: int, p2: bool) -> None: ...
    def finish(self) -> None: ...
    def write(self, p0: Any, p1: int, p2: int) -> None: ...
