from typing import Any, ClassVar, overload
from java.util.logging.Handler import Handler
from java.util.logging.Level import Level
from java.util.logging.LogRecord import LogRecord

class MemoryHandler:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: Handler, p1: int, p2: Level) -> None: ...
    def isLoggable(self, p0: LogRecord) -> bool: ...
    def setPushLevel(self, p0: Level) -> None: ...
    def getPushLevel(self) -> Level: ...
    def publish(self, p0: LogRecord) -> None: ...
    def push(self) -> None: ...
    def flush(self) -> None: ...
    def close(self) -> None: ...
