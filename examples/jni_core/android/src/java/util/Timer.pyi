from typing import Any, ClassVar, overload
from java.util.Date import Date
from java.util.TimerTask import TimerTask

class Timer:
    @overload
    def __init__(self, p0: str, p1: bool) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: bool) -> None: ...
    @overload
    def __init__(self, p0: str) -> None: ...
    def purge(self) -> int: ...
    @overload
    def scheduleAtFixedRate(self, p0: TimerTask, p1: Date, p2: int) -> None: ...
    @overload
    def scheduleAtFixedRate(self, p0: TimerTask, p1: int, p2: int) -> None: ...
    def cancel(self) -> None: ...
    @overload
    def schedule(self, p0: TimerTask, p1: int) -> None: ...
    @overload
    def schedule(self, p0: TimerTask, p1: int, p2: int) -> None: ...
    @overload
    def schedule(self, p0: TimerTask, p1: Date, p2: int) -> None: ...
    @overload
    def schedule(self, p0: TimerTask, p1: Date) -> None: ...
