from typing import Any, ClassVar, overload
from java.util.Comparator import Comparator
from java.util.SequencedCollection import SequencedCollection
from java.util.SequencedSet import SequencedSet
from java.util.Spliterator import Spliterator

class SortedSet:
    def comparator(self) -> Comparator: ...
    def subSet(self, p0: Any, p1: Any) -> "SortedSet": ...
    def headSet(self, p0: Any) -> "SortedSet": ...
    def tailSet(self, p0: Any) -> "SortedSet": ...
    @overload
    def reversed(self) -> SequencedSet: ...
    @overload
    def reversed(self) -> "SortedSet": ...
    @overload
    def reversed(self) -> SequencedCollection: ...
    def getFirst(self) -> Any: ...
    def getLast(self) -> Any: ...
    def addFirst(self, p0: Any) -> None: ...
    def addLast(self, p0: Any) -> None: ...
    def removeFirst(self) -> Any: ...
    def removeLast(self) -> Any: ...
    def last(self) -> Any: ...
    def spliterator(self) -> Spliterator: ...
    def first(self) -> Any: ...
