from typing import Any, ClassVar, overload
from java.util.Date import Date
from java.util.concurrent.TimeUnit import TimeUnit

class Condition:
    def awaitUninterruptibly(self) -> None: ...
    def awaitUntil(self, p0: Date) -> bool: ...
    @overload
    def await_(self, p0: int, p1: TimeUnit) -> bool: ...
    @overload
    def await_(self) -> None: ...
    def signal(self) -> None: ...
    def signalAll(self) -> None: ...
    def awaitNanos(self, p0: int) -> int: ...
