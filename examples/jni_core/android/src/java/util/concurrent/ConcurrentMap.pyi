from typing import Any, ClassVar, overload
from java.util.function.BiConsumer import BiConsumer
from java.util.function.BiFunction import BiFunction
from java.util.function.Function import Function

class ConcurrentMap:
    def remove(self, p0: Any, p1: Any) -> bool: ...
    @overload
    def replace(self, p0: Any, p1: Any, p2: Any) -> bool: ...
    @overload
    def replace(self, p0: Any, p1: Any) -> Any: ...
    def replaceAll(self, p0: BiFunction) -> None: ...
    def merge(self, p0: Any, p1: Any, p2: BiFunction) -> Any: ...
    def putIfAbsent(self, p0: Any, p1: Any) -> Any: ...
    def compute(self, p0: Any, p1: BiFunction) -> Any: ...
    def forEach(self, p0: BiConsumer) -> None: ...
    def computeIfAbsent(self, p0: Any, p1: Function) -> Any: ...
    def getOrDefault(self, p0: Any, p1: Any) -> Any: ...
    def computeIfPresent(self, p0: Any, p1: BiFunction) -> Any: ...
