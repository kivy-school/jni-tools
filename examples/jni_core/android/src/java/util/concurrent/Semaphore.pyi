from typing import Any, ClassVar, overload
from java.util.concurrent.TimeUnit import TimeUnit

class Semaphore:
    @overload
    def __init__(self, p0: int) -> None: ...
    @overload
    def __init__(self, p0: int, p1: bool) -> None: ...
    def drainPermits(self) -> int: ...
    @overload
    def acquireUninterruptibly(self, p0: int) -> None: ...
    @overload
    def acquireUninterruptibly(self) -> None: ...
    def availablePermits(self) -> int: ...
    def toString(self) -> str: ...
    @overload
    def release(self) -> None: ...
    @overload
    def release(self, p0: int) -> None: ...
    def hasQueuedThreads(self) -> bool: ...
    def getQueueLength(self) -> int: ...
    def isFair(self) -> bool: ...
    @overload
    def tryAcquire(self, p0: int, p1: int, p2: TimeUnit) -> bool: ...
    @overload
    def tryAcquire(self, p0: int) -> bool: ...
    @overload
    def tryAcquire(self) -> bool: ...
    @overload
    def tryAcquire(self, p0: int, p1: TimeUnit) -> bool: ...
    @overload
    def acquire(self, p0: int) -> None: ...
    @overload
    def acquire(self) -> None: ...
