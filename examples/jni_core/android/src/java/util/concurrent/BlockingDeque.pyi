from typing import Any, ClassVar, overload
from java.util.Iterator import Iterator
from java.util.concurrent.TimeUnit import TimeUnit

class BlockingDeque:
    def take(self) -> Any: ...
    def peek(self) -> Any: ...
    def pollFirst(self, p0: int, p1: TimeUnit) -> Any: ...
    def pollLast(self, p0: int, p1: TimeUnit) -> Any: ...
    @overload
    def offerLast(self, p0: Any, p1: int, p2: TimeUnit) -> bool: ...
    @overload
    def offerLast(self, p0: Any) -> bool: ...
    def removeFirstOccurrence(self, p0: Any) -> bool: ...
    @overload
    def offerFirst(self, p0: Any, p1: int, p2: TimeUnit) -> bool: ...
    @overload
    def offerFirst(self, p0: Any) -> bool: ...
    def removeLastOccurrence(self, p0: Any) -> bool: ...
    @overload
    def offer(self, p0: Any, p1: int, p2: TimeUnit) -> bool: ...
    @overload
    def offer(self, p0: Any) -> bool: ...
    @overload
    def poll(self, p0: int, p1: TimeUnit) -> Any: ...
    @overload
    def poll(self) -> Any: ...
    def putFirst(self, p0: Any) -> None: ...
    def putLast(self, p0: Any) -> None: ...
    def takeFirst(self) -> Any: ...
    def takeLast(self) -> Any: ...
    def element(self) -> Any: ...
    def addFirst(self, p0: Any) -> None: ...
    def addLast(self, p0: Any) -> None: ...
    def push(self, p0: Any) -> None: ...
    @overload
    def remove(self, p0: Any) -> bool: ...
    @overload
    def remove(self) -> Any: ...
    def size(self) -> int: ...
    def put(self, p0: Any) -> None: ...
    def add(self, p0: Any) -> bool: ...
    def iterator(self) -> Iterator: ...
    def contains(self, p0: Any) -> bool: ...
