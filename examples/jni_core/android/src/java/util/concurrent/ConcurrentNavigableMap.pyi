from typing import Any, ClassVar, overload
from java.util.NavigableMap import NavigableMap
from java.util.NavigableSet import NavigableSet
from java.util.SortedMap import SortedMap

class ConcurrentNavigableMap:
    @overload
    def descendingMap(self) -> "ConcurrentNavigableMap": ...
    @overload
    def descendingMap(self) -> NavigableMap: ...
    def navigableKeySet(self) -> NavigableSet: ...
    @overload
    def subMap(self, p0: Any, p1: bool, p2: Any, p3: bool) -> "ConcurrentNavigableMap": ...
    @overload
    def subMap(self, p0: Any, p1: bool, p2: Any, p3: bool) -> NavigableMap: ...
    @overload
    def subMap(self, p0: Any, p1: Any) -> SortedMap: ...
    @overload
    def subMap(self, p0: Any, p1: Any) -> "ConcurrentNavigableMap": ...
    @overload
    def headMap(self, p0: Any, p1: bool) -> NavigableMap: ...
    @overload
    def headMap(self, p0: Any) -> SortedMap: ...
    @overload
    def headMap(self, p0: Any, p1: bool) -> "ConcurrentNavigableMap": ...
    @overload
    def headMap(self, p0: Any) -> "ConcurrentNavigableMap": ...
    @overload
    def tailMap(self, p0: Any, p1: bool) -> "ConcurrentNavigableMap": ...
    @overload
    def tailMap(self, p0: Any, p1: bool) -> NavigableMap: ...
    @overload
    def tailMap(self, p0: Any) -> "ConcurrentNavigableMap": ...
    @overload
    def tailMap(self, p0: Any) -> SortedMap: ...
    def descendingKeySet(self) -> NavigableSet: ...
    @overload
    def keySet(self) -> NavigableSet: ...
    @overload
    def keySet(self) -> set: ...
