from typing import Any, ClassVar, overload
from java.util.concurrent.TimeUnit import TimeUnit

class TransferQueue:
    def transfer(self, p0: Any) -> None: ...
    @overload
    def tryTransfer(self, p0: Any, p1: int, p2: TimeUnit) -> bool: ...
    @overload
    def tryTransfer(self, p0: Any) -> bool: ...
    def hasWaitingConsumer(self) -> bool: ...
    def getWaitingConsumerCount(self) -> int: ...
