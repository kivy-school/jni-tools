from typing import Any, ClassVar, overload

class AtomicMarkableReference:
    def __init__(self, p0: Any, p1: bool) -> None: ...
    def compareAndSet(self, p0: Any, p1: Any, p2: bool, p3: bool) -> bool: ...
    def weakCompareAndSet(self, p0: Any, p1: Any, p2: bool, p3: bool) -> bool: ...
    def isMarked(self) -> bool: ...
    def attemptMark(self, p0: Any, p1: bool) -> bool: ...
    def get(self, p0: Any) -> Any: ...
    def getReference(self) -> Any: ...
    def set(self, p0: Any, p1: bool) -> None: ...
