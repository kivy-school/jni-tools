from typing import Any, ClassVar, overload

class AtomicBoolean:
    @overload
    def __init__(self, p0: bool) -> None: ...
    @overload
    def __init__(self) -> None: ...
    def getOpaque(self) -> bool: ...
    def setOpaque(self, p0: bool) -> None: ...
    def getAcquire(self) -> bool: ...
    def setRelease(self, p0: bool) -> None: ...
    def compareAndSet(self, p0: bool, p1: bool) -> bool: ...
    def compareAndExchange(self, p0: bool, p1: bool) -> bool: ...
    def compareAndExchangeAcquire(self, p0: bool, p1: bool) -> bool: ...
    def compareAndExchangeRelease(self, p0: bool, p1: bool) -> bool: ...
    def weakCompareAndSetPlain(self, p0: bool, p1: bool) -> bool: ...
    def weakCompareAndSet(self, p0: bool, p1: bool) -> bool: ...
    def weakCompareAndSetAcquire(self, p0: bool, p1: bool) -> bool: ...
    def weakCompareAndSetRelease(self, p0: bool, p1: bool) -> bool: ...
    def getAndSet(self, p0: bool) -> bool: ...
    def lazySet(self, p0: bool) -> None: ...
    def weakCompareAndSetVolatile(self, p0: bool, p1: bool) -> bool: ...
    def getPlain(self) -> bool: ...
    def setPlain(self, p0: bool) -> None: ...
    def get(self) -> bool: ...
    def toString(self) -> str: ...
    def set(self, p0: bool) -> None: ...
