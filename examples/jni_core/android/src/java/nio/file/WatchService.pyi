from typing import Any, ClassVar, overload
from java.nio.file.WatchKey import WatchKey
from java.util.concurrent.TimeUnit import TimeUnit

class WatchService:
    def take(self) -> WatchKey: ...
    @overload
    def poll(self, p0: int, p1: TimeUnit) -> WatchKey: ...
    @overload
    def poll(self) -> WatchKey: ...
    def close(self) -> None: ...
