from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress
from java.net.NetworkInterface import NetworkInterface
from java.nio.channels.MulticastChannel import MulticastChannel

class MembershipKey:
    def sourceAddress(self) -> InetAddress: ...
    def networkInterface(self) -> NetworkInterface: ...
    def drop(self) -> None: ...
    def isValid(self) -> bool: ...
    def unblock(self, p0: InetAddress) -> "MembershipKey": ...
    def channel(self) -> MulticastChannel: ...
    def block(self, p0: InetAddress) -> "MembershipKey": ...
    def group(self) -> InetAddress: ...
