from typing import Any, ClassVar, overload
from java.time.temporal.TemporalAdjuster import TemporalAdjuster
from java.time.temporal.TemporalAmount import TemporalAmount
from java.time.temporal.TemporalField import TemporalField
from java.time.temporal.TemporalUnit import TemporalUnit

class Temporal:
    @overload
    def plus(self, p0: int, p1: TemporalUnit) -> "Temporal": ...
    @overload
    def plus(self, p0: TemporalAmount) -> "Temporal": ...
    def until(self, p0: "Temporal", p1: TemporalUnit) -> int: ...
    @overload
    def minus(self, p0: TemporalAmount) -> "Temporal": ...
    @overload
    def minus(self, p0: int, p1: TemporalUnit) -> "Temporal": ...
    def isSupported(self, p0: TemporalUnit) -> bool: ...
    @overload
    def with_(self, p0: TemporalAdjuster) -> "Temporal": ...
    @overload
    def with_(self, p0: TemporalField, p1: int) -> "Temporal": ...
