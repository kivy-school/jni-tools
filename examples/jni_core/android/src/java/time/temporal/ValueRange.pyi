from typing import Any, ClassVar, overload
from java.time.temporal.TemporalField import TemporalField

class ValueRange:
    def checkValidValue(self, p0: int, p1: TemporalField) -> int: ...
    def isIntValue(self) -> bool: ...
    def isValidValue(self, p0: int) -> bool: ...
    def getMinimum(self) -> int: ...
    def getMaximum(self) -> int: ...
    def isValidIntValue(self, p0: int) -> bool: ...
    def isFixed(self) -> bool: ...
    def getLargestMinimum(self) -> int: ...
    def getSmallestMaximum(self) -> int: ...
    def checkValidIntValue(self, p0: int, p1: TemporalField) -> int: ...
    def equals(self, p0: Any) -> bool: ...
    def toString(self) -> str: ...
    def hashCode(self) -> int: ...
    @overload
    @staticmethod
    def of(p0: int, p1: int) -> "ValueRange": ...
    @overload
    @staticmethod
    def of(p0: int, p1: int, p2: int) -> "ValueRange": ...
    @overload
    @staticmethod
    def of(p0: int, p1: int, p2: int, p3: int) -> "ValueRange": ...
