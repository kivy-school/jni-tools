from typing import Any, ClassVar, overload
from java.lang.annotation.Annotation import Annotation

# Forward declarations for Java types we do not wrap.
# Bound as empty classes so annotations resolve in the IDE.
class AnnotatedType:
    """Forward declaration for ``java.lang.reflect.AnnotatedType``.

    This Java type is referenced by the wrapper but is not itself
    wrapped by pyjnius-wrap. At runtime pyjnius will hand you a
    live ``autoclass('java.lang.reflect.AnnotatedType')`` proxy; this empty class exists
    purely so static type checkers and IDEs can resolve the name.

    See: https://docs.oracle.com/javase/8/docs/api/java/lang/reflect/AnnotatedType.html
    """
    ...

class Executable:
    PUBLIC: ClassVar[int]
    DECLARED: ClassVar[int]
    def getGenericParameterTypes(self) -> Any: ...
    def getGenericExceptionTypes(self) -> Any: ...
    def getExceptionTypes(self) -> Any: ...
    def getAnnotatedReturnType(self) -> AnnotatedType: ...
    def getParameters(self) -> Any: ...
    def getAnnotatedReceiverType(self) -> AnnotatedType: ...
    def getAnnotatedExceptionTypes(self) -> Any: ...
    def getName(self) -> str: ...
    def getModifiers(self) -> int: ...
    def getTypeParameters(self) -> Any: ...
    def getParameterTypes(self) -> Any: ...
    def isSynthetic(self) -> bool: ...
    def toGenericString(self) -> str: ...
    def accessFlags(self) -> set: ...
    def getDeclaringClass(self) -> type: ...
    def getAnnotation(self, p0: type) -> Annotation: ...
    def getAnnotationsByType(self, p0: type) -> Any: ...
    def getDeclaredAnnotations(self) -> Any: ...
    def isVarArgs(self) -> bool: ...
    def getAnnotatedParameterTypes(self) -> Any: ...
    def getParameterCount(self) -> int: ...
    def getParameterAnnotations(self) -> Any: ...
