from typing import Any, ClassVar, overload
from java.security.Provider import Provider
from java.security.SecureRandomParameters import SecureRandomParameters

class SecureRandom:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: Any) -> None: ...
    def getAlgorithm(self) -> str: ...
    @staticmethod
    def getSeed(p0: int) -> Any: ...
    @overload
    def setSeed(self, p0: int) -> None: ...
    @overload
    def setSeed(self, p0: Any) -> None: ...
    def getParameters(self) -> SecureRandomParameters: ...
    @overload
    def nextBytes(self, p0: Any, p1: SecureRandomParameters) -> None: ...
    @overload
    def nextBytes(self, p0: Any) -> None: ...
    def generateSeed(self, p0: int) -> Any: ...
    @staticmethod
    def getInstanceStrong() -> "SecureRandom": ...
    @overload
    def reseed(self, p0: SecureRandomParameters) -> None: ...
    @overload
    def reseed(self) -> None: ...
    def getProvider(self) -> Provider: ...
    def toString(self) -> str: ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: SecureRandomParameters) -> "SecureRandom": ...
    @overload
    @staticmethod
    def getInstance(p0: str) -> "SecureRandom": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: str) -> "SecureRandom": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: Provider) -> "SecureRandom": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: SecureRandomParameters, p2: Provider) -> "SecureRandom": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: SecureRandomParameters, p2: str) -> "SecureRandom": ...
