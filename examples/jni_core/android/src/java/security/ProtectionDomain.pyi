from typing import Any, ClassVar, overload
from java.lang.ClassLoader import ClassLoader
from java.security.CodeSource import CodeSource
from java.security.Permission import Permission
from java.security.PermissionCollection import PermissionCollection

class ProtectionDomain:
    @overload
    def __init__(self, p0: CodeSource, p1: PermissionCollection) -> None: ...
    @overload
    def __init__(self, p0: CodeSource, p1: PermissionCollection, p2: ClassLoader, p3: Any) -> None: ...
    def toString(self) -> str: ...
    def getClassLoader(self) -> ClassLoader: ...
    def getCodeSource(self) -> CodeSource: ...
    def implies(self, p0: Permission) -> bool: ...
    def getPermissions(self) -> PermissionCollection: ...
    def getPrincipals(self) -> Any: ...
    def staticPermissionsOnly(self) -> bool: ...
