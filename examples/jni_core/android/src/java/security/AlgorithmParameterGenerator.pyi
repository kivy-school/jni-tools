from typing import Any, ClassVar, overload
from java.security.AlgorithmParameters import AlgorithmParameters
from java.security.Provider import Provider
from java.security.SecureRandom import SecureRandom
from java.security.spec.AlgorithmParameterSpec import AlgorithmParameterSpec

class AlgorithmParameterGenerator:
    def generateParameters(self) -> AlgorithmParameters: ...
    def getAlgorithm(self) -> str: ...
    def getProvider(self) -> Provider: ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: str) -> "AlgorithmParameterGenerator": ...
    @overload
    @staticmethod
    def getInstance(p0: str) -> "AlgorithmParameterGenerator": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: Provider) -> "AlgorithmParameterGenerator": ...
    @overload
    def init(self, p0: int, p1: SecureRandom) -> None: ...
    @overload
    def init(self, p0: AlgorithmParameterSpec, p1: SecureRandom) -> None: ...
    @overload
    def init(self, p0: AlgorithmParameterSpec) -> None: ...
    @overload
    def init(self, p0: int) -> None: ...
