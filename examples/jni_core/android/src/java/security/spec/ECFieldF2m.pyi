from typing import Any, ClassVar, overload
from java.math.BigInteger import BigInteger

class ECFieldF2m:
    @overload
    def __init__(self, p0: int) -> None: ...
    @overload
    def __init__(self, p0: int, p1: Any) -> None: ...
    @overload
    def __init__(self, p0: int, p1: BigInteger) -> None: ...
    def getReductionPolynomial(self) -> BigInteger: ...
    def getMidTermsOfReductionPolynomial(self) -> Any: ...
    def getFieldSize(self) -> int: ...
    def getM(self) -> int: ...
    def equals(self, p0: Any) -> bool: ...
    def hashCode(self) -> int: ...
