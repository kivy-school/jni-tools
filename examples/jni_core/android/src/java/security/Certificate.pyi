from typing import Any, ClassVar, overload
from java.io.InputStream import InputStream
from java.io.OutputStream import OutputStream
from java.security.Principal import Principal
from java.security.PublicKey import PublicKey

class Certificate:
    def toString(self, p0: bool) -> str: ...
    def decode(self, p0: InputStream) -> None: ...
    def encode(self, p0: OutputStream) -> None: ...
    def getFormat(self) -> str: ...
    def getPrincipal(self) -> Principal: ...
    def getGuarantor(self) -> Principal: ...
    def getPublicKey(self) -> PublicKey: ...
