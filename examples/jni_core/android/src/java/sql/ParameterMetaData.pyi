    parameterModeIn: ClassVar[int]
    parameterModeInOut: ClassVar[int]
    parameterModeOut: ClassVar[int]
    def getParameterType(self, p0: int) -> int: ...
    def getParameterTypeName(self, p0: int) -> str: ...
    def getParameterClassName(self, p0: int) -> str: ...
    def getParameterMode(self, p0: int) -> int: ...
    def isNullable(self, p0: int) -> int: ...
    def getScale(self, p0: int) -> int: ...
    def getPrecision(self, p0: int) -> int: ...
    def isSigned(self, p0: int) -> bool: ...
    def getParameterCount(self) -> int: ...
