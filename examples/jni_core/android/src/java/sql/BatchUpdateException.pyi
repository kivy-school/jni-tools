from typing import Any, ClassVar, overload
from java.lang.Throwable import Throwable

class BatchUpdateException:
    @overload
    def __init__(self, p0: Throwable) -> None: ...
    @overload
    def __init__(self, p0: Any, p1: Throwable) -> None: ...
    @overload
    def __init__(self, p0: str, p1: Any, p2: Throwable) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: Any, p3: Throwable) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: int, p3: Any, p4: Throwable) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: int, p3: Any, p4: Throwable) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: int, p3: Any) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: Any) -> None: ...
    @overload
    def __init__(self, p0: str, p1: Any) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: Any) -> None: ...
    def getUpdateCounts(self) -> Any: ...
    def getLargeUpdateCounts(self) -> Any: ...
