from typing import Any, ClassVar, overload

class BackupDataInputStream:
    def size(self) -> int: ...
    def getKey(self) -> str: ...
    @overload
    def read(self, p0: Any) -> int: ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    @overload
    def read(self) -> int: ...
