from typing import Any, ClassVar, overload
from android.graphics.ColorSpace import ColorSpace

class MeshSpecification:
    ALPHA_TYPE_OPAQUE: ClassVar[int]
    ALPHA_TYPE_PREMULTIPLIED: ClassVar[int]
    ALPHA_TYPE_UNKNOWN: ClassVar[int]
    ALPHA_TYPE_UNPREMULTIPLIED: ClassVar[int]
    TYPE_FLOAT: ClassVar[int]
    TYPE_FLOAT2: ClassVar[int]
    TYPE_FLOAT3: ClassVar[int]
    TYPE_FLOAT4: ClassVar[int]
    TYPE_UBYTE4: ClassVar[int]
    @overload
    @staticmethod
    def make(p0: Any, p1: int, p2: Any, p3: str, p4: str, p5: ColorSpace, p6: int) -> "MeshSpecification": ...
    @overload
    @staticmethod
    def make(p0: Any, p1: int, p2: Any, p3: str, p4: str, p5: ColorSpace) -> "MeshSpecification": ...
    @overload
    @staticmethod
    def make(p0: Any, p1: int, p2: Any, p3: str, p4: str) -> "MeshSpecification": ...

    class Varying:
        def __init__(self, p0: int, p1: str) -> None: ...
        def getName(self) -> str: ...
        def toString(self) -> str: ...
        def getType(self) -> int: ...

    class Attribute:
        def __init__(self, p0: int, p1: int, p2: str) -> None: ...
        def getName(self) -> str: ...
        def toString(self) -> str: ...
        def getType(self) -> int: ...
        def getOffset(self) -> int: ...
