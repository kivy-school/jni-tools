from typing import Any, ClassVar, overload

class TracingConfig:
    CATEGORIES_ALL: ClassVar[int]
    CATEGORIES_ANDROID_WEBVIEW: ClassVar[int]
    CATEGORIES_FRAME_VIEWER: ClassVar[int]
    CATEGORIES_INPUT_LATENCY: ClassVar[int]
    CATEGORIES_JAVASCRIPT_AND_RENDERING: ClassVar[int]
    CATEGORIES_NONE: ClassVar[int]
    CATEGORIES_RENDERING: ClassVar[int]
    CATEGORIES_WEB_DEVELOPER: ClassVar[int]
    RECORD_CONTINUOUSLY: ClassVar[int]
    RECORD_UNTIL_FULL: ClassVar[int]
    def getPredefinedCategories(self) -> int: ...
    def getTracingMode(self) -> int: ...
    def getCustomIncludedCategories(self) -> list: ...

    class Builder:
        def __init__(self) -> None: ...
        @overload
        def addCategories(self, p0: Any) -> Any: ...
        @overload
        def addCategories(self, p0: list) -> Any: ...
        @overload
        def addCategories(self, p0: Any) -> Any: ...
        def setTracingMode(self, p0: int) -> Any: ...
        def build(self) -> "TracingConfig": ...
