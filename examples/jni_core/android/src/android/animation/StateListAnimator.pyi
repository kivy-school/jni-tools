from typing import Any, ClassVar, overload
from android.animation.Animator import Animator

class StateListAnimator:
    def __init__(self) -> None: ...
    def addState(self, p0: Any, p1: Animator) -> None: ...
    def jumpToCurrentState(self) -> None: ...
    @overload
    def clone(self) -> Any: ...
    @overload
    def clone(self) -> "StateListAnimator": ...
