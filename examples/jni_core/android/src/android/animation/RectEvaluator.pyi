from typing import Any, ClassVar, overload
from android.graphics.Rect import Rect

class RectEvaluator:
    @overload
    def __init__(self, p0: Rect) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def evaluate(self, p0: float, p1: Any, p2: Any) -> Any: ...
    @overload
    def evaluate(self, p0: float, p1: Rect, p2: Rect) -> Rect: ...
