from typing import Any, ClassVar, overload

class FontRequest:
    @overload
    def __init__(self, p0: str, p1: str, p2: str) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: str, p3: list) -> None: ...
    def toString(self) -> str: ...
    def getCertificates(self) -> list: ...
    def getQuery(self) -> str: ...
    def getProviderPackage(self) -> str: ...
    def getProviderAuthority(self) -> str: ...
