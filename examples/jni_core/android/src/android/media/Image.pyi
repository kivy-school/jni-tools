from typing import Any, ClassVar, overload
from android.graphics.Rect import Rect
from android.hardware.HardwareBuffer import HardwareBuffer
from android.hardware.SyncFence import SyncFence
from java.nio.ByteBuffer import ByteBuffer

class Image:
    def getWidth(self) -> int: ...
    def getHeight(self) -> int: ...
    def getHardwareBuffer(self) -> HardwareBuffer: ...
    def getDataSpace(self) -> int: ...
    def getTimestamp(self) -> int: ...
    def getFormat(self) -> int: ...
    def getFence(self) -> SyncFence: ...
    def setTimestamp(self, p0: int) -> None: ...
    def setFence(self, p0: SyncFence) -> None: ...
    def setDataSpace(self, p0: int) -> None: ...
    def getCropRect(self) -> Rect: ...
    def setCropRect(self, p0: Rect) -> None: ...
    def getPlanes(self) -> Any: ...
    def close(self) -> None: ...

    class Plane:
        def getRowStride(self) -> int: ...
        def getPixelStride(self) -> int: ...
        def getBuffer(self) -> ByteBuffer: ...
