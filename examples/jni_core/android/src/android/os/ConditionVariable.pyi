from typing import Any, ClassVar, overload

class ConditionVariable:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: bool) -> None: ...
    @overload
    def block(self, p0: int) -> bool: ...
    @overload
    def block(self) -> None: ...
    def close(self) -> None: ...
    def open(self) -> None: ...
