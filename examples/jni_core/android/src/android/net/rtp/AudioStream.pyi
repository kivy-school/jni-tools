from typing import Any, ClassVar, overload
from android.net.rtp.AudioCodec import AudioCodec
from android.net.rtp.AudioGroup import AudioGroup
from java.net.InetAddress import InetAddress

class AudioStream:
    MODE_NORMAL: ClassVar[int]
    MODE_RECEIVE_ONLY: ClassVar[int]
    MODE_SEND_ONLY: ClassVar[int]
    def __init__(self, p0: InetAddress) -> None: ...
    def getDtmfType(self) -> int: ...
    def getCodec(self) -> AudioCodec: ...
    def setCodec(self, p0: AudioCodec) -> None: ...
    def setDtmfType(self, p0: int) -> None: ...
    def isBusy(self) -> bool: ...
    def getGroup(self) -> AudioGroup: ...
    def join(self, p0: AudioGroup) -> None: ...
