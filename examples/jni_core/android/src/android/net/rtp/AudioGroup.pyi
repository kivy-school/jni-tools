from typing import Any, ClassVar, overload
from android.content.Context import Context

class AudioGroup:
    MODE_ECHO_SUPPRESSION: ClassVar[int]
    MODE_MUTED: ClassVar[int]
    MODE_NORMAL: ClassVar[int]
    MODE_ON_HOLD: ClassVar[int]
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: Context) -> None: ...
    def getStreams(self) -> Any: ...
    def sendDtmf(self, p0: int) -> None: ...
    def getMode(self) -> int: ...
    def setMode(self, p0: int) -> None: ...
    def clear(self) -> None: ...
