from typing import Any, ClassVar, overload
from android.net.http.HeaderBlock import HeaderBlock

class UrlResponseInfo:
    def __init__(self) -> None: ...
    def getHeaders(self) -> HeaderBlock: ...
    def getUrlChain(self) -> list: ...
    def getHttpStatusCode(self) -> int: ...
    def getHttpStatusText(self) -> str: ...
    def wasCached(self) -> bool: ...
    def getNegotiatedProtocol(self) -> str: ...
    def getReceivedByteCount(self) -> int: ...
    def getUrl(self) -> str: ...
