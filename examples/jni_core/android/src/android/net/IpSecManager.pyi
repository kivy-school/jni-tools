from typing import Any, ClassVar, overload
from android.net.IpSecTransform import IpSecTransform
from java.io.FileDescriptor import FileDescriptor
from java.net.DatagramSocket import DatagramSocket
from java.net.InetAddress import InetAddress
from java.net.Socket import Socket

class IpSecManager:
    DIRECTION_IN: ClassVar[int]
    DIRECTION_OUT: ClassVar[int]
    @overload
    def allocateSecurityParameterIndex(self, p0: InetAddress, p1: int) -> Any: ...
    @overload
    def allocateSecurityParameterIndex(self, p0: InetAddress) -> Any: ...
    @overload
    def applyTransportModeTransform(self, p0: Socket, p1: int, p2: IpSecTransform) -> None: ...
    @overload
    def applyTransportModeTransform(self, p0: DatagramSocket, p1: int, p2: IpSecTransform) -> None: ...
    @overload
    def applyTransportModeTransform(self, p0: FileDescriptor, p1: int, p2: IpSecTransform) -> None: ...
    @overload
    def removeTransportModeTransforms(self, p0: FileDescriptor) -> None: ...
    @overload
    def removeTransportModeTransforms(self, p0: DatagramSocket) -> None: ...
    @overload
    def removeTransportModeTransforms(self, p0: Socket) -> None: ...
    @overload
    def openUdpEncapsulationSocket(self, p0: int) -> Any: ...
    @overload
    def openUdpEncapsulationSocket(self) -> Any: ...

    class UdpEncapsulationSocket:
        def getFileDescriptor(self) -> FileDescriptor: ...
        def getPort(self) -> int: ...
        def toString(self) -> str: ...
        def close(self) -> None: ...

    class SpiUnavailableException:
        def getSpi(self) -> int: ...

    class SecurityParameterIndex:
        def getSpi(self) -> int: ...
        def toString(self) -> str: ...
        def close(self) -> None: ...

    class ResourceUnavailableException:
        ...
