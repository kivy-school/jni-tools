from typing import Any, ClassVar, overload
from android.net.LocalSocket import LocalSocket
from android.net.LocalSocketAddress import LocalSocketAddress
from java.io.FileDescriptor import FileDescriptor

class LocalServerSocket:
    @overload
    def __init__(self, p0: FileDescriptor) -> None: ...
    @overload
    def __init__(self, p0: str) -> None: ...
    def getLocalSocketAddress(self) -> LocalSocketAddress: ...
    def getFileDescriptor(self) -> FileDescriptor: ...
    def accept(self) -> LocalSocket: ...
    def close(self) -> None: ...
