from typing import Any, ClassVar, overload
from android.net.MacAddress import MacAddress
from android.net.wifi.p2p.WifiP2pDevice import WifiP2pDevice
from android.os.Parcel import Parcel

class WifiP2pGroup:
    CREATOR: ClassVar[Any]
    NETWORK_ID_PERSISTENT: ClassVar[int]
    NETWORK_ID_TEMPORARY: ClassVar[int]
    SECURITY_TYPE_UNKNOWN: ClassVar[int]
    SECURITY_TYPE_WPA2_PSK: ClassVar[int]
    SECURITY_TYPE_WPA3_COMPATIBILITY: ClassVar[int]
    SECURITY_TYPE_WPA3_SAE: ClassVar[int]
    CONTENTS_FILE_DESCRIPTOR: ClassVar[int]
    PARCELABLE_WRITE_RETURN_VALUE: ClassVar[int]
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: "WifiP2pGroup") -> None: ...
    def getInterface(self) -> str: ...
    def getNetworkId(self) -> int: ...
    def getSecurityType(self) -> int: ...
    def getPassphrase(self) -> str: ...
    def isGroupOwner(self) -> bool: ...
    def getNetworkName(self) -> str: ...
    def toString(self) -> str: ...
    def getOwner(self) -> WifiP2pDevice: ...
    def writeToParcel(self, p0: Parcel, p1: int) -> None: ...
    def describeContents(self) -> int: ...
    def getClientList(self) -> list: ...
    def getFrequency(self) -> int: ...
    def getGroupOwnerBssid(self) -> MacAddress: ...
