from typing import Any, ClassVar, overload
from android.content.Context import Context
from android.graphics.Path import Path
from android.util.AttributeSet import AttributeSet

class ArcMotion:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: Context, p1: AttributeSet) -> None: ...
    def getMinimumHorizontalAngle(self) -> float: ...
    def setMaximumAngle(self, p0: float) -> None: ...
    def getMaximumAngle(self) -> float: ...
    def getMinimumVerticalAngle(self) -> float: ...
    def setMinimumHorizontalAngle(self, p0: float) -> None: ...
    def setMinimumVerticalAngle(self, p0: float) -> None: ...
    def getPath(self, p0: float, p1: float, p2: float, p3: float) -> Path: ...
