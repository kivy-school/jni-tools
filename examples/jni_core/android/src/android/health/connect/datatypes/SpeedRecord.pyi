    SPEED_MIN: ClassVar[AggregationType]
    def getSamples(self) -> list: ...
    def equals(self, p0: Any) -> bool: ...
    def hashCode(self) -> int: ...

    class SpeedRecordSample:
        def __init__(self, p0: Velocity, p1: Instant) -> None: ...
        def getSpeed(self) -> Velocity: ...
        def getTime(self) -> Instant: ...
        def equals(self, p0: Any) -> bool: ...
        def hashCode(self) -> int: ...

    class Builder:
        def __init__(self, p0: Metadata, p1: Instant, p2: Instant, p3: list) -> None: ...
        def setStartZoneOffset(self, p0: ZoneOffset) -> Any: ...
        def setEndZoneOffset(self, p0: ZoneOffset) -> Any: ...
        def clearStartZoneOffset(self) -> Any: ...
        def clearEndZoneOffset(self) -> Any: ...
        def build(self) -> "SpeedRecord": ...
