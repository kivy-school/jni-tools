from typing import Any, ClassVar, overload
from android.content.ContentValues import ContentValues
from android.net.Uri import Uri

class Entity:
    def __init__(self, p0: ContentValues) -> None: ...
    def toString(self) -> str: ...
    def getSubValues(self) -> list: ...
    def getEntityValues(self) -> ContentValues: ...
    def addSubValue(self, p0: Uri, p1: ContentValues) -> None: ...

    class NamedContentValues:
        uri: Uri
        values: ContentValues
        def __init__(self, p0: Uri, p1: ContentValues) -> None: ...
