from typing import Any, ClassVar, overload
from android.renderscript.Allocation import Allocation
from android.renderscript.Element import Element
from android.renderscript.Float4 import Float4
from android.renderscript.Matrix3f import Matrix3f
from android.renderscript.Matrix4f import Matrix4f
from android.renderscript.RenderScript import RenderScript

class ScriptIntrinsicColorMatrix:
    @overload
    def setColorMatrix(self, p0: Matrix3f) -> None: ...
    @overload
    def setColorMatrix(self, p0: Matrix4f) -> None: ...
    def setRGBtoYUV(self) -> None: ...
    def setGreyscale(self) -> None: ...
    def setYUVtoRGB(self) -> None: ...
    @overload
    def setAdd(self, p0: float, p1: float, p2: float, p3: float) -> None: ...
    @overload
    def setAdd(self, p0: Float4) -> None: ...
    @overload
    def forEach(self, p0: Allocation, p1: Allocation) -> None: ...
    @overload
    def forEach(self, p0: Allocation, p1: Allocation, p2: Any) -> None: ...
    @overload
    @staticmethod
    def create(p0: RenderScript) -> "ScriptIntrinsicColorMatrix": ...
    @overload
    @staticmethod
    def create(p0: RenderScript, p1: Element) -> "ScriptIntrinsicColorMatrix": ...
    def getKernelID(self) -> Any: ...
