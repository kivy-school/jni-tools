from typing import Any, ClassVar, overload

class Matrix2f:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: Any) -> None: ...
    def loadIdentity(self) -> None: ...
    def loadRotate(self, p0: float) -> None: ...
    def loadScale(self, p0: float, p1: float) -> None: ...
    def loadMultiply(self, p0: "Matrix2f", p1: "Matrix2f") -> None: ...
    def transpose(self) -> None: ...
    def rotate(self, p0: float) -> None: ...
    def multiply(self, p0: "Matrix2f") -> None: ...
    def getArray(self) -> Any: ...
    def get(self, p0: int, p1: int) -> float: ...
    def load(self, p0: "Matrix2f") -> None: ...
    def scale(self, p0: float, p1: float) -> None: ...
    def set(self, p0: int, p1: int, p2: float) -> None: ...
