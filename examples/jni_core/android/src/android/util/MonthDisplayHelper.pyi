from typing import Any, ClassVar, overload

class MonthDisplayHelper:
    @overload
    def __init__(self, p0: int, p1: int, p2: int) -> None: ...
    @overload
    def __init__(self, p0: int, p1: int) -> None: ...
    def getFirstDayOfMonth(self) -> int: ...
    def getNumberOfDaysInMonth(self) -> int: ...
    def getDigitsForRow(self, p0: int) -> Any: ...
    def getDayAt(self, p0: int, p1: int) -> int: ...
    def getRowOf(self, p0: int) -> int: ...
    def getColumnOf(self, p0: int) -> int: ...
    def getWeekStartDay(self) -> int: ...
    def previousMonth(self) -> None: ...
    def nextMonth(self) -> None: ...
    def isWithinCurrentMonth(self, p0: int, p1: int) -> bool: ...
    def getMonth(self) -> int: ...
    def getOffset(self) -> int: ...
    def getYear(self) -> int: ...
