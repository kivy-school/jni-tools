from typing import Any, ClassVar, overload

class Rational:
    NEGATIVE_INFINITY: ClassVar["Rational"]
    NaN: ClassVar["Rational"]
    POSITIVE_INFINITY: ClassVar["Rational"]
    ZERO: ClassVar["Rational"]
    def __init__(self, p0: int, p1: int) -> None: ...
    def getNumerator(self) -> int: ...
    def getDenominator(self) -> int: ...
    @staticmethod
    def parseRational(p0: str) -> "Rational": ...
    def equals(self, p0: Any) -> bool: ...
    def toString(self) -> str: ...
    def hashCode(self) -> int: ...
    def isInfinite(self) -> bool: ...
    def isFinite(self) -> bool: ...
    @overload
    def compareTo(self, p0: "Rational") -> int: ...
    @overload
    def compareTo(self, p0: Any) -> int: ...
    def shortValue(self) -> int: ...
    def intValue(self) -> int: ...
    def longValue(self) -> int: ...
    def floatValue(self) -> float: ...
    def doubleValue(self) -> float: ...
    def isNaN(self) -> bool: ...
    def isZero(self) -> bool: ...
