from typing import Any, ClassVar, overload
from android.bluetooth.le.AdvertisingSet import AdvertisingSet

class AdvertisingSetCallback:
    ADVERTISE_FAILED_ALREADY_STARTED: ClassVar[int]
    ADVERTISE_FAILED_DATA_TOO_LARGE: ClassVar[int]
    ADVERTISE_FAILED_FEATURE_UNSUPPORTED: ClassVar[int]
    ADVERTISE_FAILED_INTERNAL_ERROR: ClassVar[int]
    ADVERTISE_FAILED_TOO_MANY_ADVERTISERS: ClassVar[int]
    ADVERTISE_SUCCESS: ClassVar[int]
    def __init__(self) -> None: ...
    def onAdvertisingSetStarted(self, p0: AdvertisingSet, p1: int, p2: int) -> None: ...
    def onAdvertisingSetStopped(self, p0: AdvertisingSet) -> None: ...
    def onAdvertisingEnabled(self, p0: AdvertisingSet, p1: bool, p2: int) -> None: ...
    def onAdvertisingDataSet(self, p0: AdvertisingSet, p1: int) -> None: ...
    def onScanResponseDataSet(self, p0: AdvertisingSet, p1: int) -> None: ...
    def onAdvertisingParametersUpdated(self, p0: AdvertisingSet, p1: int, p2: int) -> None: ...
    def onPeriodicAdvertisingDataSet(self, p0: AdvertisingSet, p1: int) -> None: ...
    def onPeriodicAdvertisingParametersUpdated(self, p0: AdvertisingSet, p1: int) -> None: ...
    def onPeriodicAdvertisingEnabled(self, p0: AdvertisingSet, p1: bool, p2: int) -> None: ...
