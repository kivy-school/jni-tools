from typing import Any, ClassVar, overload
from java.sql.Connection import Connection
from javax.sql.ConnectionEventListener import ConnectionEventListener
from javax.sql.StatementEventListener import StatementEventListener

class PooledConnection:
    def addConnectionEventListener(self, p0: ConnectionEventListener) -> None: ...
    def removeConnectionEventListener(self, p0: ConnectionEventListener) -> None: ...
    def addStatementEventListener(self, p0: StatementEventListener) -> None: ...
    def removeStatementEventListener(self, p0: StatementEventListener) -> None: ...
    def getConnection(self) -> Connection: ...
    def close(self) -> None: ...
