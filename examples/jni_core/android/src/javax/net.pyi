from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress
from java.net.Socket import Socket

class SocketFactory:
    @overload
    def createSocket(self, p0: InetAddress, p1: int) -> Socket: ...
    @overload
    def createSocket(self, p0: str, p1: int, p2: InetAddress, p3: int) -> Socket: ...
    @overload
    def createSocket(self, p0: InetAddress, p1: int, p2: InetAddress, p3: int) -> Socket: ...
    @overload
    def createSocket(self, p0: str, p1: int) -> Socket: ...
    @overload
    def createSocket(self) -> Socket: ...
    @staticmethod
    def getDefault() -> "SocketFactory": ...

from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress
from java.net.ServerSocket import ServerSocket

class ServerSocketFactory:
    @staticmethod
    def getDefault() -> "ServerSocketFactory": ...
    @overload
    def createServerSocket(self, p0: int, p1: int) -> ServerSocket: ...
    @overload
    def createServerSocket(self, p0: int, p1: int, p2: InetAddress) -> ServerSocket: ...
    @overload
    def createServerSocket(self, p0: int) -> ServerSocket: ...
    @overload
    def createServerSocket(self) -> ServerSocket: ...

