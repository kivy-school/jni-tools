from typing import Any, ClassVar, overload
from java.security.Provider import Provider
from java.security.spec.KeySpec import KeySpec
from javax.crypto.SecretKey import SecretKey

class SecretKeyFactory:
    def getProvider(self) -> Provider: ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: Provider) -> "SecretKeyFactory": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: str) -> "SecretKeyFactory": ...
    @overload
    @staticmethod
    def getInstance(p0: str) -> "SecretKeyFactory": ...
    def getAlgorithm(self) -> str: ...
    def getKeySpec(self, p0: SecretKey, p1: type) -> KeySpec: ...
    def translateKey(self, p0: SecretKey) -> SecretKey: ...
    def generateSecret(self, p0: KeySpec) -> SecretKey: ...
