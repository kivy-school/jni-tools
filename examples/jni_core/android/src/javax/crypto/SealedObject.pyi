from typing import Any, ClassVar, overload
from java.io.Serializable import Serializable
from java.security.Key import Key
from javax.crypto.Cipher import Cipher

class SealedObject:
    def __init__(self, p0: Serializable, p1: Cipher) -> None: ...
    @overload
    def getObject(self, p0: Cipher) -> Any: ...
    @overload
    def getObject(self, p0: Key) -> Any: ...
    @overload
    def getObject(self, p0: Key, p1: str) -> Any: ...
    def getAlgorithm(self) -> str: ...
