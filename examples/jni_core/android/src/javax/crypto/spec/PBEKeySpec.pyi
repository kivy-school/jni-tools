from typing import Any, ClassVar, overload

class PBEKeySpec:
    @overload
    def __init__(self, p0: Any, p1: Any, p2: int) -> None: ...
    @overload
    def __init__(self, p0: Any, p1: Any, p2: int, p3: int) -> None: ...
    @overload
    def __init__(self, p0: Any) -> None: ...
    def getPassword(self) -> Any: ...
    def clearPassword(self) -> None: ...
    def getIterationCount(self) -> int: ...
    def getSalt(self) -> Any: ...
    def getKeyLength(self) -> int: ...
