from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress
from java.net.ServerSocket import ServerSocket

class ServerSocketFactory:
    @overload
    def createServerSocket(self, p0: int, p1: int) -> ServerSocket: ...
    @overload
    def createServerSocket(self, p0: int, p1: int, p2: InetAddress) -> ServerSocket: ...
    @overload
    def createServerSocket(self) -> ServerSocket: ...
    @overload
    def createServerSocket(self, p0: int) -> ServerSocket: ...
    @staticmethod
    def getDefault() -> "ServerSocketFactory": ...
