from typing import Any, ClassVar, overload

class LexicalHandler:
    def startDTD(self, p0: str, p1: str, p2: str) -> None: ...
    def endDTD(self) -> None: ...
    def startEntity(self, p0: str) -> None: ...
    def endEntity(self, p0: str) -> None: ...
    def startCDATA(self) -> None: ...
    def endCDATA(self) -> None: ...
    def comment(self, p0: Any, p1: int, p2: int) -> None: ...
