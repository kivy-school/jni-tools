from typing import Any, ClassVar, overload
from java.security.Key import Key
from java.security.Provider import Provider
from java.security.SecureRandom import SecureRandom
from java.security.spec.AlgorithmParameterSpec import AlgorithmParameterSpec
from javax.crypto.SecretKey import SecretKey

class KeyAgreement:
    def getProvider(self) -> Provider: ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: str) -> "KeyAgreement": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: Provider) -> "KeyAgreement": ...
    @overload
    @staticmethod
    def getInstance(p0: str) -> "KeyAgreement": ...
    @overload
    def init(self, p0: Key, p1: SecureRandom) -> None: ...
    @overload
    def init(self, p0: Key, p1: AlgorithmParameterSpec) -> None: ...
    @overload
    def init(self, p0: Key, p1: AlgorithmParameterSpec, p2: SecureRandom) -> None: ...
    @overload
    def init(self, p0: Key) -> None: ...
    def getAlgorithm(self) -> str: ...
    @overload
    def generateSecret(self) -> Any: ...
    @overload
    def generateSecret(self, p0: Any, p1: int) -> int: ...
    @overload
    def generateSecret(self, p0: str) -> SecretKey: ...
    def doPhase(self, p0: Key, p1: bool) -> Key: ...
