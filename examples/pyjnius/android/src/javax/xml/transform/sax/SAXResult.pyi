from typing import Any, ClassVar, overload
from org.xml.sax.ContentHandler import ContentHandler
from org.xml.sax.ext.LexicalHandler import LexicalHandler

class SAXResult:
    FEATURE: ClassVar[str]
    PI_DISABLE_OUTPUT_ESCAPING: ClassVar[str]
    PI_ENABLE_OUTPUT_ESCAPING: ClassVar[str]
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: ContentHandler) -> None: ...
    def getSystemId(self) -> str: ...
    def setSystemId(self, p0: str) -> None: ...
    def getHandler(self) -> ContentHandler: ...
    def setHandler(self, p0: ContentHandler) -> None: ...
    def setLexicalHandler(self, p0: LexicalHandler) -> None: ...
    def getLexicalHandler(self) -> LexicalHandler: ...
