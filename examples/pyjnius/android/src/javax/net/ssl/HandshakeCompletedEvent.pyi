from typing import Any, ClassVar, overload
from java.security.Principal import Principal
from javax.net.ssl.SSLSession import SSLSession
from javax.net.ssl.SSLSocket import SSLSocket

class HandshakeCompletedEvent:
    def __init__(self, p0: SSLSocket, p1: SSLSession) -> None: ...
    def getSession(self) -> SSLSession: ...
    def getCipherSuite(self) -> str: ...
    def getPeerPrincipal(self) -> Principal: ...
    def getLocalPrincipal(self) -> Principal: ...
    def getPeerCertificates(self) -> Any: ...
    def getLocalCertificates(self) -> Any: ...
    def getPeerCertificateChain(self) -> Any: ...
    def getSocket(self) -> SSLSocket: ...
