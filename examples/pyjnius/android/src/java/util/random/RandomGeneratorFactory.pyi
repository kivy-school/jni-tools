from typing import Any, ClassVar, overload
from java.math.BigInteger import BigInteger
from java.util.random.RandomGenerator import RandomGenerator
from java.util.stream.Stream import Stream

class RandomGeneratorFactory:
    def name(self) -> str: ...
    def group(self) -> str: ...
    @staticmethod
    def of(p0: str) -> "RandomGeneratorFactory": ...
    @staticmethod
    def getDefault() -> "RandomGeneratorFactory": ...
    @overload
    def create(self) -> RandomGenerator: ...
    @overload
    def create(self, p0: Any) -> RandomGenerator: ...
    @overload
    def create(self, p0: int) -> RandomGenerator: ...
    def period(self) -> BigInteger: ...
    def isDeprecated(self) -> bool: ...
    @staticmethod
    def all() -> Stream: ...
    def stateBits(self) -> int: ...
    def equidistribution(self) -> int: ...
    def isStochastic(self) -> bool: ...
    def isHardware(self) -> bool: ...
    def isStatistical(self) -> bool: ...
    def isArbitrarilyJumpable(self) -> bool: ...
    def isJumpable(self) -> bool: ...
    def isLeapable(self) -> bool: ...
    def isSplittable(self) -> bool: ...
    def isStreamable(self) -> bool: ...
