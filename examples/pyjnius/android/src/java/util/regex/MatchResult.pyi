from typing import Any, ClassVar, overload

class MatchResult:
    def namedGroups(self) -> dict: ...
    @overload
    def group(self, p0: int) -> str: ...
    @overload
    def group(self, p0: str) -> str: ...
    @overload
    def group(self) -> str: ...
    @overload
    def end(self) -> int: ...
    @overload
    def end(self, p0: str) -> int: ...
    @overload
    def end(self, p0: int) -> int: ...
    @overload
    def start(self, p0: int) -> int: ...
    @overload
    def start(self, p0: str) -> int: ...
    @overload
    def start(self) -> int: ...
    def hasMatch(self) -> bool: ...
    def groupCount(self) -> int: ...
