from typing import Any, ClassVar, overload
from java.util.SequencedCollection import SequencedCollection
from java.util.SequencedSet import SequencedSet

class SequencedMap:
    def sequencedKeySet(self) -> SequencedSet: ...
    def sequencedValues(self) -> SequencedCollection: ...
    def sequencedEntrySet(self) -> SequencedSet: ...
    def putFirst(self, p0: Any, p1: Any) -> Any: ...
    def putLast(self, p0: Any, p1: Any) -> Any: ...
    def firstEntry(self) -> Any: ...
    def lastEntry(self) -> Any: ...
    def pollFirstEntry(self) -> Any: ...
    def pollLastEntry(self) -> Any: ...
    def reversed(self) -> "SequencedMap": ...
