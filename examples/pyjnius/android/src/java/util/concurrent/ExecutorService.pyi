    def isTerminated(self) -> bool: ...
    @overload
    def submit(self, p0: Runnable, p1: Any) -> Future: ...
    @overload
    def submit(self, p0: Callable) -> Future: ...
    @overload
    def submit(self, p0: Runnable) -> Future: ...
    def isShutdown(self) -> bool: ...
    @overload
    def invokeAll(self, p0: list, p1: int, p2: TimeUnit) -> list: ...
    @overload
    def invokeAll(self, p0: list) -> list: ...
    @overload
    def invokeAny(self, p0: list, p1: int, p2: TimeUnit) -> Any: ...
    @overload
    def invokeAny(self, p0: list) -> Any: ...
    def shutdownNow(self) -> list: ...
    def awaitTermination(self, p0: int, p1: TimeUnit) -> bool: ...
