from typing import Any, ClassVar, overload
from java.util.Comparator import Comparator
from java.util.SequencedMap import SequencedMap

class SortedMap:
    def values(self) -> list: ...
    def entrySet(self) -> set: ...
    def keySet(self) -> set: ...
    def comparator(self) -> Comparator: ...
    def putFirst(self, p0: Any, p1: Any) -> Any: ...
    def putLast(self, p0: Any, p1: Any) -> Any: ...
    def subMap(self, p0: Any, p1: Any) -> "SortedMap": ...
    def headMap(self, p0: Any) -> "SortedMap": ...
    def tailMap(self, p0: Any) -> "SortedMap": ...
    def lastKey(self) -> Any: ...
    @overload
    def reversed(self) -> "SortedMap": ...
    @overload
    def reversed(self) -> SequencedMap: ...
    def firstKey(self) -> Any: ...
