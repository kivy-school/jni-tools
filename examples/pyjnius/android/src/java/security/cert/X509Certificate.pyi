from typing import Any, ClassVar, overload
from java.math.BigInteger import BigInteger
from java.security.Principal import Principal
from java.security.Provider import Provider
from java.security.PublicKey import PublicKey
from java.util.Date import Date
from javax.security.auth.x500.X500Principal import X500Principal

class X509Certificate:
    def getSignature(self) -> Any: ...
    def getBasicConstraints(self) -> int: ...
    def getIssuerX500Principal(self) -> X500Principal: ...
    def getSubjectX500Principal(self) -> X500Principal: ...
    def getExtendedKeyUsage(self) -> list: ...
    def getSubjectAlternativeNames(self) -> list: ...
    def getIssuerAlternativeNames(self) -> list: ...
    def getSigAlgName(self) -> str: ...
    def getSigAlgParams(self) -> Any: ...
    def getTBSCertificate(self) -> Any: ...
    @overload
    def checkValidity(self) -> None: ...
    @overload
    def checkValidity(self, p0: Date) -> None: ...
    def getSerialNumber(self) -> BigInteger: ...
    def getIssuerDN(self) -> Principal: ...
    def getSubjectDN(self) -> Principal: ...
    def getNotBefore(self) -> Date: ...
    def getNotAfter(self) -> Date: ...
    def getSigAlgOID(self) -> str: ...
    def getIssuerUniqueID(self) -> Any: ...
    def getSubjectUniqueID(self) -> Any: ...
    def getKeyUsage(self) -> Any: ...
    def getVersion(self) -> int: ...
    def verify(self, p0: PublicKey, p1: Provider) -> None: ...
