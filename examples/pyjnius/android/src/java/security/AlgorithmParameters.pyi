from typing import Any, ClassVar, overload
from java.security.Provider import Provider
from java.security.spec.AlgorithmParameterSpec import AlgorithmParameterSpec

class AlgorithmParameters:
    def getProvider(self) -> Provider: ...
    def getParameterSpec(self, p0: type) -> AlgorithmParameterSpec: ...
    def toString(self) -> str: ...
    @overload
    @staticmethod
    def getInstance(p0: str) -> "AlgorithmParameters": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: str) -> "AlgorithmParameters": ...
    @overload
    @staticmethod
    def getInstance(p0: str, p1: Provider) -> "AlgorithmParameters": ...
    @overload
    def init(self, p0: AlgorithmParameterSpec) -> None: ...
    @overload
    def init(self, p0: Any, p1: str) -> None: ...
    @overload
    def init(self, p0: Any) -> None: ...
    @overload
    def getEncoded(self, p0: str) -> Any: ...
    @overload
    def getEncoded(self) -> Any: ...
    def getAlgorithm(self) -> str: ...
