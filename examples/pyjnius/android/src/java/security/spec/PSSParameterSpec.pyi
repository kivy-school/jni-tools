from typing import Any, ClassVar, overload
from java.security.spec.AlgorithmParameterSpec import AlgorithmParameterSpec

class PSSParameterSpec:
    TRAILER_FIELD_BC: ClassVar[int]
    DEFAULT: ClassVar["PSSParameterSpec"]
    @overload
    def __init__(self, p0: str, p1: str, p2: AlgorithmParameterSpec, p3: int, p4: int) -> None: ...
    @overload
    def __init__(self, p0: int) -> None: ...
    def toString(self) -> str: ...
    def getDigestAlgorithm(self) -> str: ...
    def getMGFAlgorithm(self) -> str: ...
    def getMGFParameters(self) -> AlgorithmParameterSpec: ...
    def getSaltLength(self) -> int: ...
    def getTrailerField(self) -> int: ...
