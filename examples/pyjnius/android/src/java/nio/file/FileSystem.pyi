from java.nio.file.attribute.UserPrincipalLookupService import UserPrincipalLookupService
from java.nio.file.spi.FileSystemProvider import FileSystemProvider

class FileSystem:
    def isOpen(self) -> bool: ...
    def close(self) -> None: ...
    def provider(self) -> FileSystemProvider: ...
    def getPath(self, p0: str, p1: Any) -> Path: ...
    def getSeparator(self) -> str: ...
    def supportedFileAttributeViews(self) -> set: ...
    def newWatchService(self) -> WatchService: ...
    def isReadOnly(self) -> bool: ...
    def getRootDirectories(self) -> Iterable: ...
