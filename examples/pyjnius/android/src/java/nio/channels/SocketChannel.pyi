from typing import Any, ClassVar, overload
from java.net.ProtocolFamily import ProtocolFamily
from java.net.Socket import Socket
from java.net.SocketAddress import SocketAddress
from java.net.SocketOption import SocketOption
from java.nio.ByteBuffer import ByteBuffer
from java.nio.channels.NetworkChannel import NetworkChannel

class SocketChannel:
    def connect(self, p0: SocketAddress) -> bool: ...
    def isConnected(self) -> bool: ...
    def getRemoteAddress(self) -> SocketAddress: ...
    @overload
    def write(self, p0: ByteBuffer) -> int: ...
    @overload
    def write(self, p0: Any, p1: int, p2: int) -> int: ...
    @overload
    def write(self, p0: Any) -> int: ...
    @overload
    @staticmethod
    def open(p0: SocketAddress) -> "SocketChannel": ...
    @overload
    @staticmethod
    def open(p0: ProtocolFamily) -> "SocketChannel": ...
    @overload
    @staticmethod
    def open() -> "SocketChannel": ...
    @overload
    def read(self, p0: Any, p1: int, p2: int) -> int: ...
    @overload
    def read(self, p0: Any) -> int: ...
    @overload
    def read(self, p0: ByteBuffer) -> int: ...
    @overload
    def bind(self, p0: SocketAddress) -> "SocketChannel": ...
    @overload
    def bind(self, p0: SocketAddress) -> NetworkChannel: ...
    def isConnectionPending(self) -> bool: ...
    def finishConnect(self) -> bool: ...
    def validOps(self) -> int: ...
    def socket(self) -> Socket: ...
    def getLocalAddress(self) -> SocketAddress: ...
    @overload
    def setOption(self, p0: SocketOption, p1: Any) -> NetworkChannel: ...
    @overload
    def setOption(self, p0: SocketOption, p1: Any) -> "SocketChannel": ...
    def shutdownInput(self) -> "SocketChannel": ...
    def shutdownOutput(self) -> "SocketChannel": ...
