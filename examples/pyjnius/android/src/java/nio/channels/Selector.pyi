from typing import Any, ClassVar, overload
from java.nio.channels.spi.SelectorProvider import SelectorProvider
from java.util.function.Consumer import Consumer

class Selector:
    @overload
    def select(self, p0: int) -> int: ...
    @overload
    def select(self, p0: Consumer, p1: int) -> int: ...
    @overload
    def select(self, p0: Consumer) -> int: ...
    @overload
    def select(self) -> int: ...
    def isOpen(self) -> bool: ...
    def close(self) -> None: ...
    def provider(self) -> SelectorProvider: ...
    def keys(self) -> set: ...
    @staticmethod
    def open() -> "Selector": ...
    def selectedKeys(self) -> set: ...
    @overload
    def selectNow(self, p0: Consumer) -> int: ...
    @overload
    def selectNow(self) -> int: ...
    def wakeup(self) -> "Selector": ...
