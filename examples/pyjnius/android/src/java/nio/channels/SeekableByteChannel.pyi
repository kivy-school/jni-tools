from typing import Any, ClassVar, overload
from java.nio.ByteBuffer import ByteBuffer

class SeekableByteChannel:
    def size(self) -> int: ...
    @overload
    def position(self, p0: int) -> "SeekableByteChannel": ...
    @overload
    def position(self) -> int: ...
    def write(self, p0: ByteBuffer) -> int: ...
    def read(self, p0: ByteBuffer) -> int: ...
    def truncate(self, p0: int) -> "SeekableByteChannel": ...
