from typing import Any, ClassVar, overload
from java.io.PrintWriter import PrintWriter
from java.io.Reader import Reader
from java.nio.charset.Charset import Charset
from java.util.Locale import Locale

class Console:
    def isTerminal(self) -> bool: ...
    def flush(self) -> None: ...
    @overload
    def format(self, p0: str, p1: Any) -> "Console": ...
    @overload
    def format(self, p0: Locale, p1: str, p2: Any) -> "Console": ...
    def charset(self) -> Charset: ...
    @overload
    def readLine(self) -> str: ...
    @overload
    def readLine(self, p0: Locale, p1: str, p2: Any) -> str: ...
    @overload
    def readLine(self, p0: str, p1: Any) -> str: ...
    def reader(self) -> Reader: ...
    def writer(self) -> PrintWriter: ...
    @overload
    def printf(self, p0: str, p1: Any) -> "Console": ...
    @overload
    def printf(self, p0: Locale, p1: str, p2: Any) -> "Console": ...
    @overload
    def readPassword(self, p0: Locale, p1: str, p2: Any) -> Any: ...
    @overload
    def readPassword(self) -> Any: ...
    @overload
    def readPassword(self, p0: str, p1: Any) -> Any: ...
