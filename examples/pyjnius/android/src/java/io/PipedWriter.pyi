from typing import Any, ClassVar, overload
from java.io.PipedReader import PipedReader

class PipedWriter:
    @overload
    def __init__(self, p0: PipedReader) -> None: ...
    @overload
    def __init__(self) -> None: ...
    def connect(self, p0: PipedReader) -> None: ...
    def flush(self) -> None: ...
