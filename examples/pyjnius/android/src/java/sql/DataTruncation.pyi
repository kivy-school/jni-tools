from typing import Any, ClassVar, overload
from java.lang.Throwable import Throwable

class DataTruncation:
    @overload
    def __init__(self, p0: int, p1: bool, p2: bool, p3: int, p4: int, p5: Throwable) -> None: ...
    @overload
    def __init__(self, p0: int, p1: bool, p2: bool, p3: int, p4: int) -> None: ...
    def getDataSize(self) -> int: ...
    def getRead(self) -> bool: ...
    def getTransferSize(self) -> int: ...
    def getParameter(self) -> bool: ...
    def getIndex(self) -> int: ...
