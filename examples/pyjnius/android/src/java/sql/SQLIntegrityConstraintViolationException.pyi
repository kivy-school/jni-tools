from typing import Any, ClassVar, overload
from java.lang.Throwable import Throwable

class SQLIntegrityConstraintViolationException:
    @overload
    def __init__(self, p0: Throwable) -> None: ...
    @overload
    def __init__(self, p0: str, p1: Throwable) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: Throwable) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: int, p3: Throwable) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: str) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str) -> None: ...
    @overload
    def __init__(self, p0: str, p1: str, p2: int) -> None: ...
