from typing import Any, ClassVar, overload
from java.text.AttributedCharacterIterator import AttributedCharacterIterator

class Bidi:
    DIRECTION_LEFT_TO_RIGHT: ClassVar[int]
    DIRECTION_RIGHT_TO_LEFT: ClassVar[int]
    DIRECTION_DEFAULT_LEFT_TO_RIGHT: ClassVar[int]
    DIRECTION_DEFAULT_RIGHT_TO_LEFT: ClassVar[int]
    @overload
    def __init__(self, p0: Any, p1: int, p2: Any, p3: int, p4: int, p5: int) -> None: ...
    @overload
    def __init__(self, p0: AttributedCharacterIterator) -> None: ...
    @overload
    def __init__(self, p0: str, p1: int) -> None: ...
    def baseIsLeftToRight(self) -> bool: ...
    def createLineBidi(self, p0: int, p1: int) -> "Bidi": ...
    def getBaseLevel(self) -> int: ...
    def getLevelAt(self, p0: int) -> int: ...
    def getRunCount(self) -> int: ...
    def getRunLevel(self, p0: int) -> int: ...
    def isLeftToRight(self) -> bool: ...
    def isMixed(self) -> bool: ...
    @staticmethod
    def reorderVisually(p0: Any, p1: int, p2: Any, p3: int, p4: int) -> None: ...
    @staticmethod
    def requiresBidi(p0: Any, p1: int, p2: int) -> bool: ...
    def toString(self) -> str: ...
    def getLength(self) -> int: ...
    def isRightToLeft(self) -> bool: ...
    def getRunStart(self, p0: int) -> int: ...
    def getRunLimit(self, p0: int) -> int: ...
