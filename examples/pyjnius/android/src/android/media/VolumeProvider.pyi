from typing import Any, ClassVar, overload

class VolumeProvider:
    VOLUME_CONTROL_ABSOLUTE: ClassVar[int]
    VOLUME_CONTROL_FIXED: ClassVar[int]
    VOLUME_CONTROL_RELATIVE: ClassVar[int]
    @overload
    def __init__(self, p0: int, p1: int, p2: int, p3: str) -> None: ...
    @overload
    def __init__(self, p0: int, p1: int, p2: int) -> None: ...
    def getVolumeControlId(self) -> str: ...
    def onAdjustVolume(self, p0: int) -> None: ...
    def onSetVolumeTo(self, p0: int) -> None: ...
    def setCurrentVolume(self, p0: int) -> None: ...
    def getCurrentVolume(self) -> int: ...
    def getMaxVolume(self) -> int: ...
    def getVolumeControl(self) -> int: ...
