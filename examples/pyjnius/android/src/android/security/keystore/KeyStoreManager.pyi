from typing import Any, ClassVar, overload
from java.security.Key import Key
from java.security.KeyPair import KeyPair

class KeyStoreManager:
    MODULE_HASH: ClassVar[int]
    def getGrantedCertificateChainFromId(self, p0: int) -> list: ...
    def getGrantedKeyFromId(self, p0: int) -> Key: ...
    def getGrantedKeyPairFromId(self, p0: int) -> KeyPair: ...
    def getSupplementaryAttestationInfo(self, p0: int) -> Any: ...
    def grantKeyAccess(self, p0: str, p1: int) -> int: ...
    def revokeKeyAccess(self, p0: str, p1: int) -> None: ...
