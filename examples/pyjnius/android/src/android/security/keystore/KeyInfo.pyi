from typing import Any, ClassVar, overload
from java.util.Date import Date

class KeyInfo:
    def getDigests(self) -> Any: ...
    def getEncryptionPaddings(self) -> Any: ...
    def getBlockModes(self) -> Any: ...
    def getKeySize(self) -> int: ...
    def getKeyValidityForConsumptionEnd(self) -> Date: ...
    def getKeyValidityForOriginationEnd(self) -> Date: ...
    def getKeyValidityStart(self) -> Date: ...
    def getKeystoreAlias(self) -> str: ...
    def getPurposes(self) -> int: ...
    def getSignaturePaddings(self) -> Any: ...
    def getUserAuthenticationType(self) -> int: ...
    def getUserAuthenticationValidityDurationSeconds(self) -> int: ...
    def isInvalidatedByBiometricEnrollment(self) -> bool: ...
    def isUserAuthenticationRequired(self) -> bool: ...
    def isUserAuthenticationValidWhileOnBody(self) -> bool: ...
    def isUserConfirmationRequired(self) -> bool: ...
    def getOrigin(self) -> int: ...
    def getSecurityLevel(self) -> int: ...
    def getRemainingUsageCount(self) -> int: ...
    def isInsideSecureHardware(self) -> bool: ...
    def isTrustedUserPresenceRequired(self) -> bool: ...
    def isUserAuthenticationRequirementEnforcedBySecureHardware(self) -> bool: ...
