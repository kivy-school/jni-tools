from typing import Any, ClassVar, overload
from android.os.IBinder import IBinder
from android.os.Parcel import Parcel
from android.view.inputmethod.InputConnection import InputConnection

class InputBinding:
    CREATOR: ClassVar[Any]
    CONTENTS_FILE_DESCRIPTOR: ClassVar[int]
    PARCELABLE_WRITE_RETURN_VALUE: ClassVar[int]
    @overload
    def __init__(self, p0: InputConnection, p1: IBinder, p2: int, p3: int) -> None: ...
    @overload
    def __init__(self, p0: InputConnection, p1: "InputBinding") -> None: ...
    def getConnection(self) -> InputConnection: ...
    def getConnectionToken(self) -> IBinder: ...
    def toString(self) -> str: ...
    def getPid(self) -> int: ...
    def getUid(self) -> int: ...
    def writeToParcel(self, p0: Parcel, p1: int) -> None: ...
    def describeContents(self) -> int: ...
