from typing import Any, ClassVar, overload
from android.hardware.usb.UsbInterface import UsbInterface
from android.os.Parcel import Parcel

class UsbConfiguration:
    CREATOR: ClassVar[Any]
    CONTENTS_FILE_DESCRIPTOR: ClassVar[int]
    PARCELABLE_WRITE_RETURN_VALUE: ClassVar[int]
    def getName(self) -> str: ...
    def toString(self) -> str: ...
    def getId(self) -> int: ...
    def getInterface(self, p0: int) -> UsbInterface: ...
    def getInterfaceCount(self) -> int: ...
    def isRemoteWakeup(self) -> bool: ...
    def isSelfPowered(self) -> bool: ...
    def getMaxPower(self) -> int: ...
    def writeToParcel(self, p0: Parcel, p1: int) -> None: ...
    def describeContents(self) -> int: ...
