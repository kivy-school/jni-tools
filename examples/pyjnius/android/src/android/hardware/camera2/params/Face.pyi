from typing import Any, ClassVar, overload
from android.graphics.Point import Point
from android.graphics.Rect import Rect

class Face:
    ID_UNSUPPORTED: ClassVar[int]
    SCORE_MAX: ClassVar[int]
    SCORE_MIN: ClassVar[int]
    def toString(self) -> str: ...
    def getBounds(self) -> Rect: ...
    def getId(self) -> int: ...
    def getScore(self) -> int: ...
    def getMouthPosition(self) -> Point: ...
    def getRightEyePosition(self) -> Point: ...
    def getLeftEyePosition(self) -> Point: ...

    class Builder:
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, p0: "Face") -> None: ...
        def setMouthPosition(self, p0: Point) -> Any: ...
        def setLeftEyePosition(self, p0: Point) -> Any: ...
        def setRightEyePosition(self, p0: Point) -> Any: ...
        def setScore(self, p0: int) -> Any: ...
        def setId(self, p0: int) -> Any: ...
        def build(self) -> "Face": ...
        def setBounds(self, p0: Rect) -> Any: ...
