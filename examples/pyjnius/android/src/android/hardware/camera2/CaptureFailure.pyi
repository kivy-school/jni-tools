from typing import Any, ClassVar, overload
from android.hardware.camera2.CaptureRequest import CaptureRequest

class CaptureFailure:
    REASON_ERROR: ClassVar[int]
    REASON_FLUSHED: ClassVar[int]
    def wasImageCaptured(self) -> bool: ...
    def getFrameNumber(self) -> int: ...
    def getRequest(self) -> CaptureRequest: ...
    def getSequenceId(self) -> int: ...
    def getPhysicalCameraId(self) -> str: ...
    def getReason(self) -> int: ...
