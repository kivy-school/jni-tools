    VERSION_JAR: ClassVar[int]
    VERSION_SIGNING_BLOCK_V2: ClassVar[int]
    VERSION_SIGNING_BLOCK_V3: ClassVar[int]
    VERSION_SIGNING_BLOCK_V4: ClassVar[int]
    CONTENTS_FILE_DESCRIPTOR: ClassVar[int]
    PARCELABLE_WRITE_RETURN_VALUE: ClassVar[int]
    @overload
    def __init__(self, p0: int, p1: list, p2: list, p3: list) -> None: ...
    @overload
    def __init__(self, p0: "SigningInfo") -> None: ...
    @overload
    def __init__(self) -> None: ...
    def hasMultipleSigners(self) -> bool: ...
    def getSchemeVersion(self) -> int: ...
    def getPublicKeys(self) -> list: ...
    def getApkContentsSigners(self) -> Any: ...
    def getSigningCertificateHistory(self) -> Any: ...
    def hasPastSigningCertificates(self) -> bool: ...
    def signersMatchExactly(self, p0: "SigningInfo") -> bool: ...
    def writeToParcel(self, p0: Parcel, p1: int) -> None: ...
    def describeContents(self) -> int: ...
