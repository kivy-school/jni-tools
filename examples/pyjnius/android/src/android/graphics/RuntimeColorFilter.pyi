from typing import Any, ClassVar, overload
from android.graphics.Color import Color
from android.graphics.ColorFilter import ColorFilter
from android.graphics.RuntimeXfermode import RuntimeXfermode
from android.graphics.Shader import Shader

class RuntimeColorFilter:
    def __init__(self, p0: str) -> None: ...
    @overload
    def setFloatUniform(self, p0: str, p1: float) -> None: ...
    @overload
    def setFloatUniform(self, p0: str, p1: float, p2: float) -> None: ...
    @overload
    def setFloatUniform(self, p0: str, p1: float, p2: float, p3: float) -> None: ...
    @overload
    def setFloatUniform(self, p0: str, p1: float, p2: float, p3: float, p4: float) -> None: ...
    @overload
    def setFloatUniform(self, p0: str, p1: Any) -> None: ...
    @overload
    def setIntUniform(self, p0: str, p1: int) -> None: ...
    @overload
    def setIntUniform(self, p0: str, p1: int, p2: int, p3: int, p4: int) -> None: ...
    @overload
    def setIntUniform(self, p0: str, p1: int, p2: int, p3: int) -> None: ...
    @overload
    def setIntUniform(self, p0: str, p1: int, p2: int) -> None: ...
    @overload
    def setIntUniform(self, p0: str, p1: Any) -> None: ...
    @overload
    def setColorUniform(self, p0: str, p1: int) -> None: ...
    @overload
    def setColorUniform(self, p0: str, p1: Color) -> None: ...
    @overload
    def setColorUniform(self, p0: str, p1: int) -> None: ...
    def setInputXfermode(self, p0: str, p1: RuntimeXfermode) -> None: ...
    def setInputShader(self, p0: str, p1: Shader) -> None: ...
    def setInputColorFilter(self, p0: str, p1: ColorFilter) -> None: ...
