from typing import Any, ClassVar, overload
from android.graphics.Canvas import Canvas

class TransitionDrawable:
    INSET_UNDEFINED: ClassVar[int]
    PADDING_MODE_NEST: ClassVar[int]
    PADDING_MODE_STACK: ClassVar[int]
    def __init__(self, p0: Any) -> None: ...
    def reverseTransition(self, p0: int) -> None: ...
    def resetTransition(self) -> None: ...
    def isCrossFadeEnabled(self) -> bool: ...
    def setCrossFadeEnabled(self, p0: bool) -> None: ...
    def startTransition(self, p0: int) -> None: ...
    def draw(self, p0: Canvas) -> None: ...
