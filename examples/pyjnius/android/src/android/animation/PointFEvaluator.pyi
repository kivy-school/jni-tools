from typing import Any, ClassVar, overload
from android.graphics.PointF import PointF

class PointFEvaluator:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p0: PointF) -> None: ...
    @overload
    def evaluate(self, p0: float, p1: Any, p2: Any) -> Any: ...
    @overload
    def evaluate(self, p0: float, p1: PointF, p2: PointF) -> PointF: ...
