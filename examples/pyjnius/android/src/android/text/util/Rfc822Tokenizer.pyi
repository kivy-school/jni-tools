from typing import Any, ClassVar, overload

class Rfc822Tokenizer:
    def __init__(self) -> None: ...
    @overload
    @staticmethod
    def tokenize(p0: str, p1: list) -> None: ...
    @overload
    @staticmethod
    def tokenize(p0: str) -> Any: ...
    def findTokenEnd(self, p0: str, p1: int) -> int: ...
    def findTokenStart(self, p0: str, p1: int) -> int: ...
    def terminateToken(self, p0: str) -> str: ...
