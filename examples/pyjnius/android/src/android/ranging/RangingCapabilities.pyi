from typing import Any, ClassVar, overload
from android.os.Parcel import Parcel
from android.ranging.ble.cs.BleCsRangingCapabilities import BleCsRangingCapabilities
from android.ranging.uwb.UwbRangingCapabilities import UwbRangingCapabilities
from android.ranging.wifi.rtt.RttRangingCapabilities import RttRangingCapabilities

class RangingCapabilities:
    CREATOR: ClassVar[Any]
    DISABLED_REGULATORY: ClassVar[int]
    DISABLED_USER: ClassVar[int]
    DISABLED_USER_RESTRICTIONS: ClassVar[int]
    ENABLED: ClassVar[int]
    NOT_SUPPORTED: ClassVar[int]
    CONTENTS_FILE_DESCRIPTOR: ClassVar[int]
    PARCELABLE_WRITE_RETURN_VALUE: ClassVar[int]
    def toString(self) -> str: ...
    def getCsCapabilities(self) -> BleCsRangingCapabilities: ...
    def getRttRangingCapabilities(self) -> RttRangingCapabilities: ...
    def getTechnologyAvailability(self) -> dict: ...
    def getUwbCapabilities(self) -> UwbRangingCapabilities: ...
    def writeToParcel(self, p0: Parcel, p1: int) -> None: ...
    def describeContents(self) -> int: ...
