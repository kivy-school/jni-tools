from typing import Any, ClassVar, overload

class ProfilingTrigger:
    TRIGGER_TYPE_ANR: ClassVar[int]
    TRIGGER_TYPE_APP_FULLY_DRAWN: ClassVar[int]
    TRIGGER_TYPE_NONE: ClassVar[int]
    def getTriggerType(self) -> int: ...
    def getRateLimitingPeriodHours(self) -> int: ...

    class Builder:
        def __init__(self, p0: int) -> None: ...
        def build(self) -> "ProfilingTrigger": ...
        def setRateLimitingPeriodHours(self, p0: int) -> Any: ...
