from typing import Any, ClassVar, overload
from android.net.http.SslCertificate import SslCertificate
from java.security.cert.X509Certificate import X509Certificate

class SslError:
    SSL_DATE_INVALID: ClassVar[int]
    SSL_EXPIRED: ClassVar[int]
    SSL_IDMISMATCH: ClassVar[int]
    SSL_INVALID: ClassVar[int]
    SSL_MAX_ERROR: ClassVar[int]
    SSL_NOTYETVALID: ClassVar[int]
    SSL_UNTRUSTED: ClassVar[int]
    @overload
    def __init__(self, p0: int, p1: X509Certificate, p2: str) -> None: ...
    @overload
    def __init__(self, p0: int, p1: X509Certificate) -> None: ...
    @overload
    def __init__(self, p0: int, p1: SslCertificate, p2: str) -> None: ...
    @overload
    def __init__(self, p0: int, p1: SslCertificate) -> None: ...
    def toString(self) -> str: ...
    def addError(self, p0: int) -> bool: ...
    def getPrimaryError(self) -> int: ...
    def getCertificate(self) -> SslCertificate: ...
    def getUrl(self) -> str: ...
    def hasError(self, p0: int) -> bool: ...
