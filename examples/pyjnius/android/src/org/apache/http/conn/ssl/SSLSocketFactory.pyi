from typing import Any, ClassVar, overload
from java.net.InetAddress import InetAddress
from java.net.Socket import Socket
from java.security.KeyStore import KeyStore
from java.security.SecureRandom import SecureRandom
from org.apache.http.conn.scheme.HostNameResolver import HostNameResolver
from org.apache.http.conn.ssl.X509HostnameVerifier import X509HostnameVerifier
from org.apache.http.params.HttpParams import HttpParams

class SSLSocketFactory:
    ALLOW_ALL_HOSTNAME_VERIFIER: ClassVar[X509HostnameVerifier]
    BROWSER_COMPATIBLE_HOSTNAME_VERIFIER: ClassVar[X509HostnameVerifier]
    SSL: ClassVar[str]
    SSLV2: ClassVar[str]
    STRICT_HOSTNAME_VERIFIER: ClassVar[X509HostnameVerifier]
    TLS: ClassVar[str]
    @overload
    def __init__(self, p0: str, p1: KeyStore, p2: str, p3: KeyStore, p4: SecureRandom, p5: HostNameResolver) -> None: ...
    @overload
    def __init__(self, p0: KeyStore) -> None: ...
    @overload
    def __init__(self, p0: KeyStore, p1: str) -> None: ...
    @overload
    def __init__(self, p0: KeyStore, p1: str, p2: KeyStore) -> None: ...
    @staticmethod
    def getSocketFactory() -> "SSLSocketFactory": ...
    @overload
    def createSocket(self, p0: Socket, p1: str, p2: int, p3: bool) -> Socket: ...
    @overload
    def createSocket(self) -> Socket: ...
    def connectSocket(self, p0: Socket, p1: str, p2: int, p3: InetAddress, p4: int, p5: HttpParams) -> Socket: ...
    def isSecure(self, p0: Socket) -> bool: ...
    def setHostnameVerifier(self, p0: X509HostnameVerifier) -> None: ...
    def getHostnameVerifier(self) -> X509HostnameVerifier: ...
